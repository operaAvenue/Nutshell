  file_change {
    absolute_path_uri: "file:///src/components/NodeMonitor.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { ESP32Node, PinMode } from \'../types\';\nimport { Wifi, Plus, Search, Server, Power, Activity, HardDrive, RefreshCw, Layers } from \'lucide-react\';\n\ninterface NodeMonitorProps {\n  nodes: ESP32Node[];\n  onAddNode: (node: ESP32Node) => void;\n  onUpdateNodePin: (nodeIp: string, gpio: number, newValue: number) => void;\n  onAddLog: (source: \'SYSTEM\' | \'WIFI\' | \'HTTP\' | \'GPIO\' | \'ERROR\', message: string) => void;\n}\n\nexport default function NodeMonitor({ nodes, onAddNode, onUpdateNodePin, onAddLog }: NodeMonitorProps) {\n  const [isScanning, setIsScanning] = useState(false);\n  const [showAddForm, setShowAddForm] = useState(false);\n  \n  // Form values\n  const [newHostname, setNewHostname] = useState(\'\');\n  const [newIp, setNewIp] = useState(\'\');\n  const [newRole, setNewRole] = useState<\'COORDINATOR\' | \'NODE\'>(\'NODE\');\n\n  const getRssiColor = (rssi: number) => {\n    if (rssi >= -50) return \'text-emerald-400\';\n    if (rssi >= -70) return \'text-amber-400\';\n    return \'text-rose-450\';\n  };\n\n  const getRssiLabel = (rssi: number) => {\n    if (rssi >= -50) return \'Excelente\';\n    if (rssi >= -70) return \'Regular\';\n    return \'Fraco\';\n  };\n\n  const handleScan = () => {\n    setIsScanning(true);\n    onAddLog(\'WIFI\', \'Iniciando escaneamento de rede mDNS local...\');\n    \n    setTimeout(() => {\n      setIsScanning(false);\n      onAddLog(\'WIFI\', `Escanemaneto conclu\303\255do! Encontrados ${nodes.length} n\303\263s ESP32 ativos na rede.`);\n      onAddLog(\'HTTP\', \'Atualizado mapeamento de n\303\263s da malha P2P.\');\n    }, 2000);\n  };\n\n  const handleCreateNode = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newHostname || !newIp) {\n      onAddLog(\'ERROR\', \'Falha ao adicionar n\303\263: Preencha todos os campos!\');\n      return;\n    }\n\n    // Basic IP validation\n    const ipRegex = /^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}$/;\n    if (!ipRegex.test(newIp)) {\n      onAddLog(\'ERROR\', \'Falha ao adicionar n\303\263: formato de IP inv\303\241lido!\');\n      return;\n    }\n\n    const newNode: ESP32Node = {\n      ip: newIp,\n      hostname: newHostname.toLowerCase().replace(/\\s+/g, \'-\'),\n      isOnline: true,\n      rssi: -55 - Math.floor(Math.random() * 25), // random rssi\n      role: newRole,\n      lastSeen: \"Agora mesmo\",\n      pinStates: {\n        2: { mode: \"DIGITAL_OUTPUT\", customLabel: \"Onboard LED (Azul)\", value: 0 },\n        4: { mode: \"DIGITAL_OUTPUT\", customLabel: \"Rel\303\251 Auxiliar\", value: 0 }\n      }\n    };\n\n    onAddNode(newNode);\n    onAddLog(\'SYSTEM\', `Novo n\303\263 configurado: ${newNode.hostname} em [http://${newNode.ip}]`);\n    \n    // Clear state\n    setNewHostname(\'\');\n    setNewIp(\'\');\n    setNewRole(\'NODE\');\n    setShowAddForm(false);\n  };\n\n  const handleToggleRemotePin = (ip: string, gpio: number, currentVal: number) => {\n    const newVal = currentVal === 0 ? 1 : 0;\n    onUpdateNodePin(ip, gpio, newVal);\n    onAddLog(\'HTTP\', `HTTP GET http://${ip}/api/toggle?pin=${gpio}&val=${newVal} -> Respondido 200 OK`);\n  };\n\n  return (\n    <div className=\"flex flex-col gap-5\">\n      {/* Network Header with dynamic stats */}\n      <div className=\"bg-neutral-900/60 p-5 rounded-3xl border border-neutral-800 backdrop-blur-sm\">\n        <div className=\"flex justify-between items-center bg-neutral-950/40 p-4 rounded-2xl border border-neutral-850\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"p-2 border border-blue-500/10 bg-blue-600/5 text-blue-400 rounded-xl\">\n              <Layers className=\"w-5 h-5 animate-pulse\" />\n            </div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-xs font-bold uppercase tracking-wider text-neutral-300\">Malha de Dispositivos</span>\n              <span className=\"text-[10px] font-mono text-neutral-500\">{nodes.filter(n => n.isOnline).length} Dispositivos Online</span>\n            </div>\n          </div>\n\n          <div className=\"flex items-center gap-2\">\n            <button \n              onClick={handleScan}\n              disabled={isScanning}\n              className={`p-2 rounded-xl text-neutral-400 border border-neutral-850 hover:border-neutral-700/80 hover:text-neutral-200 transition-all ${isScanning ? \'animate-spin border-cyan-500/30 text-cyan-400 bg-cyan-950/20\' : \'bg-neutral-950\'}`}\n            >\n              <RefreshCw className=\"w-4 h-4\" />\n            </button>\n            <button \n              onClick={() => setShowAddForm(!showAddForm)}\n              className={`flex items-center gap-1.5 px-3 py-2 rounded-xl text-[10.5px] font-bold border transition-all ${showAddForm ? \'bg-neutral-800 border-neutral-700 text-neutral-300\' : \'bg-blue-600 border-blue-500/80 text-white shadow-md shadow-blue-600/10 active:bg-blue-700\'}`}\n            >\n              <Plus className=\"w-3.5 h-3.5\" /> Adicionar N\303\263\n            </button>\n          </div>\n        </div>\n\n        {/* Dynamic add new device form */}\n        {showAddForm && (\n          <form onSubmit={handleCreateNode} className=\"mt-4 p-4 rounded-2xl border border-neutral-800 bg-neutral-950/80 flex flex-col gap-3\">\n            <h5 className=\"text-[10.5px] font-bold uppercase tracking-widest text-neutral-300 font-mono\">Conectar novo ESP32</h5>\n            <div className=\"grid grid-cols-2 gap-3.5\">\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-[9px] font-mono font-bold text-neutral-400 uppercase tracking-wider\">Hostname mDNS</label>\n                <input \n                  type=\"text\" \n                  value={newHostname}\n                  onChange={(e) => setNewHostname(e.target.value)}\n                  placeholder=\"Ex: esp32-corredor\"\n                  className=\"bg-neutral-900 border border-neutral-800 text-xs px-2.5 py-2 rounded-xl text-neutral-200 outline-none focus:border-blue-500/50\"\n                  required\n                />\n              </div>\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-[9px] font-mono font-bold text-neutral-400 uppercase tracking-wider\">Ender\303\247o IP Fixo</label>\n                <input \n                  type=\"text\" \n                  value={newIp}\n                  onChange={(e) => setNewIp(e.target.value)}\n                  placeholder=\"Ex: 192.168.4.45\"\n                  className=\"bg-neutral-900 border border-neutral-800 text-xs px-2.5 py-2 rounded-xl text-neutral-200 outline-none focus:border-blue-500/50\"\n                  required\n                />\n              </div>\n            </div>\n\n            <div className=\"flex items-center justify-between mt-1\">\n              <div className=\"flex items-center gap-4\">\n                <span className=\"text-[9px] font-mono font-bold text-neutral-400 uppercase\">Fun\303\247\303\243o na Rede:</span>\n                <label className=\"flex items-center gap-1.5 cursor-pointer text-[10.5px] text-neutral-300 select-none\">\n                  <input \n                    type=\"radio\" \n                    name=\"role\" \n                    checked={newRole === \'NODE\'} \n                    onChange={() => setNewRole(\'NODE\')}\n                    className=\"accent-blue-500\" \n                  />\n                  N\303\263 Regular\n                </label>\n                <label className=\"flex items-center gap-1.5 cursor-pointer text-[10.5px] text-neutral-300 select-none\">\n                  <input \n                    type=\"radio\" \n                    name=\"role\" \n                    checked={newRole === \'COORDINATOR\'} \n                    onChange={() => setNewRole(\'COORDINATOR\')}\n                    className=\"accent-blue-500\" \n                  />\n                  Coordenador\n                </label>\n              </div>\n\n              <div className=\"flex gap-2\">\n                <button \n                  type=\"button\" \n                  onClick={() => setShowAddForm(false)}\n                  className=\"px-2.5 py-1.5 rounded-lg text-[10.5px] text-neutral-400 hover:text-neutral-200 transition-all font-mono\"\n                >\n                  Cancelar\n                </button>\n                <button \n                  type=\"submit\" \n                  className=\"bg-blue-600 border border-blue-500/70 hover:bg-blue-700 text-white font-bold px-3 py-1.5 rounded-lg text-[10.5px]\"\n                >\n                  Confirmar\n                </button>\n              </div>\n            </div>\n          </form>\n        )}\n      </div>\n\n      {/* Nodes list cards view */}\n      <div className=\"flex flex-col gap-3.5\">\n        {nodes.map((node) => {\n          return (\n            <div \n              key={node.ip} \n              className={`bg-neutral-900/60 p-4.5 rounded-3xl border transition-all ${\n                node.role === \'COORDINATOR\' \n                  ? \'border-neutral-800 border-l-4 border-l-blue-500\' \n                  : \'border-neutral-800\'\n              }`}\n            >\n              {/* Card Header information */}\n              <div className=\"flex justify-between items-start gap-2 border-b border-neutral-850 pb-3 mb-3\">\n                <div className=\"flex items-center gap-3\">\n                  <div className={`p-2.5 rounded-2xl border ${node.role === \'COORDINATOR\' ? \'bg-blue-950/40 border-blue-900/40 text-blue-400\' : \'bg-neutral-950 border-neutral-850 text-cyan-400\'}`}>\n                    <Server className=\"w-4 h-4\" />\n                  </div>\n                  <div className=\"flex flex-col\">\n                    <div className=\"flex items-center gap-1.5\">\n                      <span className=\"text-xs font-bold text-neutral-200\">{node.hostname}.local</span>\n                      <span className={`text-[8px] font-mono px-2 py-0.5 rounded-full uppercase ${node.role === \'COORDINATOR\' ? \'bg-blue-950/50 border border-blue-900/70 text-blue-400\' : \'bg-neutral-950 border border-neutral-800 text-neutral-500\'}`}>\n                        {node.role === \'COORDINATOR\' ? \'Coord / AP\' : \'N\303\263 Wifi\'}\n                      </span>\n                    </div>\n                    <span className=\"text-[10px] text-neutral-500 font-mono\">{node.ip}</span>\n                  </div>\n                </div>\n\n                <div className=\"text-right flex flex-col items-end gap-1 font-mono text-[9.5px]\">\n                  <div className=\"flex items-center gap-1.5\">\n                    <Wifi className={`w-3.5 h-3.5 ${getRssiColor(node.rssi)}`} />\n                    <span className={`font-bold ${getRssiColor(node.rssi)}`}>{node.rssi} dBm</span>\n                  </div>\n                  <span className=\"text-[8px] text-neutral-500\">Sinal: {getRssiLabel(node.rssi)}</span>\n                </div>\n              </div>\n\n              {/* Node Remote Pin Controllers */}\n              <div className=\"flex flex-col gap-2.5\">\n                <span className=\"text-[9px] font-mono uppercase tracking-widest text-neutral-500 font-bold block mb-1\">\n                  Controle Direto Transparente (Local mDNS)\n                </span>\n\n                <div className=\"grid grid-cols-2 gap-2\">\n                  {Object.entries(node.pinStates).map(([gpioStr, pin]) => {\n                    const gpio = parseInt(gpioStr, 10);\n                    const isOutput = pin.mode === \'DIGITAL_OUTPUT\';\n                    const isAnalog = pin.mode === \'ANALOG_INPUT\';\n                    const isPwm = pin.mode === \'PWM_OUTPUT\';\n\n                    return (\n                      <div \n                        key={gpio} \n                        className=\"bg-neutral-950/40 border border-neutral-850/80 p-2.5 rounded-2xl flex items-center justify-between text-xs\"\n                      >\n                        <div className=\"truncate pr-1\">\n                          <p className=\"font-semibold text-[11px] truncate text-neutral-300\">\n                            {pin.customLabel}\n                          </p>\n                          <span className=\"text-[8.5px] font-mono text-neutral-500\">\n                            GPIO {gpio} \342\200\242 {pin.mode === \'DIGITAL_OUTPUT\' ? \'OUT\' : \'ADC\'}\n                          </span>\n                        </div>\n\n                        {/* Interactive toggle for remote digital outputs */}\n                        {isOutput ? (\n                          <button \n                            onClick={() => handleToggleRemotePin(node.ip, gpio, pin.value)}\n                            className={`p-1.5 rounded-full border transition-all ${\n                              pin.value === 1 \n                                ? \'bg-emerald-950/50 border-emerald-800/80 text-emerald-400\' \n                                : \'bg-neutral-900 border-neutral-800 text-neutral-500 hover:text-neutral-300\'\n                            }`}\n                          >\n                            <Power className=\"w-4 h-4\" />\n                          </button>\n                        ) : isAnalog ? (\n                          <span className=\"bg-purple-950/30 border border-purple-900/50 px-2 py-0.5 rounded-lg text-[9.5px] text-purple-400 font-mono\">\n                            {pin.value}\n                          </span>\n                        ) : (\n                          <span className=\"bg-cyan-950/30 border border-cyan-900/50 px-2 py-0.5 rounded-lg text-[9.5px] text-cyan-400 font-mono\">\n                            {pin.value}\n                          </span>\n                        )}\n                      </div>\n                    );\n                  })}\n                </div>\n              </div>\n\n              {/* Node signal details footer */}\n              <div className=\"flex justify-between items-center text-[8.5px] font-mono text-neutral-500 mt-3 pt-2.5 border-t border-neutral-850/40\">\n                <span>Servidor HTTP Interno: Ativo</span>\n                <span>\303\232ltimo Ping mDNS: {node.lastSeen}</span>\n              </div>\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n"
    }
