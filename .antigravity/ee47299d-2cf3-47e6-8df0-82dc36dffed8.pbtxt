        target_content: "      {/* Workspace Prompt box */}\n      <div className=\"bg-neutral-900/60 p-5 rounded-3xl border border-neutral-800 backdrop-blur-sm flex flex-col min-h-[300px]\">\n        <div className=\"relative flex-1 flex flex-col justify-between\">\n          \n          {/* Output responses or helpers */}\n          <div className=\"flex-1 mb-5\">\n            {loading ? (\n              <div className=\"h-full min-h-[1400px: max-h-[220px]] flex flex-col items-center justify-center gap-3 py-10\">\n                <div className=\"relative h-9 w-9 rounded-full border-t-2 border-l-2 border-cyan-400 animate-spin\" />\n                <div className=\"flex flex-col items-center\">\n                  <span className=\"text-xs font-bold text-cyan-400 font-mono tracking-widest uppercase animate-pulse\">Compila\303\247\303\243o Inteligente</span>\n                  <span className=\"text-[10px] text-neutral-500 font-mono mt-1 text-center\">Consultando eletr\303\264nica do ESP32 Maker Genius...</span>\n                </div>\n              </div>\n            ) : error ? (\n              <div className=\"flex items-start gap-2.5 bg-rose-950/15 border border-rose-900/40 p-4 rounded-2xl my-4 text-rose-300\">\n                <AlertCircle className=\"w-4.5 h-4.5 flex-shrink-0 mt-0.5\" />\n                <div className=\"flex flex-col gap-0.5\">\n                  <span className=\"text-[10.5px] font-bold font-mono uppercase tracking-wider\">Falha de Inst\303\242ncia</span>\n                  <p className=\"text-[10px] leading-relaxed\">{error}</p>\n                </div>\n              </div>\n            ) : response ? (\n              <div className=\"bg-neutral-950/45 border border-neutral-850 p-5 rounded-2xl max-h-[420px] overflow-y-auto select-text shadow-inner\">\n                {renderSimpleMarkdown(response)}\n              </div>\n            ) : (\n              <div className=\"border border-dashed border-neutral-850 bg-neutral-950/10 p-8 rounded-2xl text-center flex flex-col items-center gap-2 text-neutral-500 py-10 leading-normal\">\n                <MessageSquare className=\"w-7 h-7 text-neutral-600 animate-pulse\" />\n                <span className=\"text-[11px] font-bold text-neutral-400\">Canal Livre para Chat Assist\303\252ncia</span>\n                <p className=\"text-[10px] text-neutral-500 max-w-sm\">\n                  Escreva sua d\303\272vida t\303\251cnica no campo abaixo ou selecione um dos bot\303\265es r\303\241pidos de instru\303\247\303\265es acima para acelerar o desenvolvimento.\n                </p>\n              </div>\n            )}\n          </div>\n\n          {/* Form prompts inputs */}\n          <div className=\"flex gap-2\">\n            <input \n              type=\"text\" \n              value={prompt}\n              onChange={(e) => setPrompt(e.target.value)}\n              disabled={loading}\n              placeholder=\"Perguntar sobre sensores, deep-sleep, Wi-Fi mesh..\"\n              className=\"flex-1 bg-neutral-950 border border-neutral-850 hover:border-neutral-800 text-xs px-3.5 py-3 rounded-2xl text-neutral-200 outline-none focus:border-blue-500/80 transition-all font-medium disabled:opacity-45\"\n              onKeyDown={(e) => {\n                if (e.key === \'Enter\' && prompt.trim()) {\n                  handleAskGemini(prompt);\n                }\n              }}\n            />\n            <button \n              onClick={() => handleAskGemini(prompt)}\n              disabled={loading || !prompt.trim()}\n              className=\"px-4.5 py-3 rounded-2xl bg-cyan-600 hover:bg-cyan-700 font-bold border border-cyan-500/85 text-white shadow-lg shadow-cyan-600/10 active:scale-95 transition-all text-xs flex items-center justify-center gap-1.5 disabled:opacity-45 disabled:pointer-events-none\"\n            >\n              <Send className=\"w-3.5 h-3.5\" />\n              <span>Enviar</span>\n            </button>\n          </div>"
        replacement_content: "      {/* Workspace Prompt box */}\n      <div className=\"bg-[#1C1F2B] p-5 rounded-3xl border border-white/5 flex flex-col min-h-[300px] shadow-inner\">\n        <div className=\"relative flex-1 flex flex-col justify-between\">\n          \n          {/* Output responses or helpers */}\n          <div className=\"flex-1 mb-5\">\n            {loading ? (\n              <div className=\"h-full min-h-[220px] flex flex-col items-center justify-center gap-3 py-10\">\n                <div className=\"relative h-9 w-9 rounded-full border-t-2 border-l-2 border-cyan-400 animate-spin\" />\n                <div className=\"flex flex-col items-center\">\n                  <span className=\"text-xs font-bold text-cyan-400 font-mono tracking-widest uppercase animate-pulse\">Compila\303\247\303\243o Inteligente</span>\n                  <span className=\"text-[10px] text-slate-500 font-mono mt-1 text-center\">Consultando eletr\303\264nica do ESP32 Maker Genius...</span>\n                </div>\n              </div>\n            ) : error ? (\n              <div className=\"flex items-start gap-2.5 bg-rose-950/15 border border-rose-900/40 p-4 rounded-2xl my-4 text-rose-300\">\n                <AlertCircle className=\"w-4.5 h-4.5 flex-shrink-0 mt-0.5 animate-bounce\" />\n                <div className=\"flex flex-col gap-0.5\">\n                  <span className=\"text-[10.5px] font-bold font-mono uppercase tracking-wider\">Falha de Inst\303\242ncia</span>\n                  <p className=\"text-[10px] leading-relaxed\">{error}</p>\n                </div>\n              </div>\n            ) : response ? (\n              <div className=\"bg-[#12141C] border border-[#252833]/60 p-5 rounded-2xl max-h-[420px] overflow-y-auto select-text shadow-inner\">\n                {renderSimpleMarkdown(response)}\n              </div>\n            ) : (\n              <div className=\"border border-dashed border-[#252833]/65 bg-[#12141C]/35 p-8 rounded-2xl text-center