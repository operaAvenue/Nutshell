    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Cpu, Send, Sparkles, MessageSquare, Code, Settings, HelpCircle, AlertCircle } from \'lucide-react\';\n\ninterface AiAssistantProps {\n  onAddLog: (source: \'SYSTEM\' | \'WIFI\' | \'HTTP\' | \'GPIO\' | \'ERROR\', message: string) => void;\n}\n\nexport default function AiAssistant({ onAddLog }: AiAssistantProps) {\n  const [prompt, setPrompt] = useState(\'\');\n  const [response, setResponse] = useState<string>(\'\');\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n\n  const quickPrompts = [\n    { label: \'Sensor DHT22\', text: \'Como ler temperatura e umidade com sensor DHT22 e enviar os dados para o meu dashboard na GPIO 15? Mostre as conex\303\265es dos pinos e o c\303\263digo C++.\' },\n    { label: \'Deep Sleep\', text: \'Como configurar o Deep Sleep no ESP32 para acordar a cada 15 minutos com RTC timer de modo a economizar o m\303\241ximo de bateria? Mostre o c\303\263digo b\303\241sico.\' },\n    { label: \'Blink sem Delay\', text: \'Escreva um c\303\263digo em Arduino/C++ para piscar um LED na GPIO 2 e ler um bot\303\243o na GPIO 4 simultaneamente, usando timers (millis()) em vez de delays bloqueantes.\' }\n  ];\n\n  const handleAskGemini = async (textToSend: string) => {\n    if (!textToSend.trim()) return;\n    setLoading(true);\n    setError(null);\n    setResponse(\'\');\n    \n    onAddLog(\'SYSTEM\', `Iniciando consulta ao ESP32 Maker Genius AI com o prompt: \"${textToSend.substring(0, 30)}...\"`);\n\n    try {\n      const res = await fetch(\'/api/gemini/assist\', {\n        method: \'POST\',\n        headers: {\n          \'Content-Type\': \'application/json\'\n        },\n        body: JSON.stringify({ prompt: textToSend })\n      });\n\n      if (!res.ok) {\n        throw new Error(\'Falha ao obter resposta do servidor. C\303\263digo: \' + res.status);\n      }\n\n      const data = await res.json();\n      setResponse(data.text || \'Sem resposta dispon\303\255vel.\');\n      onAddLog(\'SYSTEM\', \'Resposta do assistente de IA recebida com sucesso.\');\n    } catch (err: any) {\n      console.error(err);\n      setError(err.message || \'Erro de rede ao conectar com o servi\303\247o de Intelig\303\252ncia Artificial.\');\n      onAddLog(\'ERROR\', \'Falha na consulta do assistente de IA: \' + err.message);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  // Safe and clean regex-based markdown parser so we do not need heavy packages! Fits beautifully onto ESP32 memory limit.\n  const renderSimpleMarkdown = (markdown: string) => {\n    if (!markdown) return null;\n\n    const sections = markdown.split(/(```[\\s\\S]*?```)/g);\n\n    return sections.map((section, idx) => {\n      // If code block\n      if (section.startsWith(\'```\')) {\n        const lines = section.split(\'\\n\');\n        const language = lines[0].replace(\'```\', \'\').trim() || \'cpp\';\n        const codeContent = lines.slice(1, lines.length - 1).join(\'\\n\');\n        \n        return (\n          <div key={idx} className=\"my-4.5 rounded-2xl border border-neutral-800 bg-black/60 overflow-hidden font-mono text-[10px]\">\n            <div className=\"bg-neutral-900 px-4 py-2 border-b border-neutral-800 flex justify-between items-center text-neutral-500 text-[9px] uppercase tracking-wide\">\n              <span className=\"flex items-center gap-1.5 text-cyan-400 font-bold\">\n                <Code className=\"w-3.5 h-3.5 text-cyan-500\" /> {language}\n              </span>\n              <span>ESP32 FIRMWARE SNIPPET</span>\n            </div>\n            <pre className=\"p-4 overflow-x-auto text-neutral-300 leading-relaxed whitespace-pre font-light select-text\">\n              {codeContent}\n            </pre>\n          </div>\n        );\n      }\n\n      // If normal text block, let\'s parse simple bold stars AND headers\n      const renderedLines = section.split(\'\\n\').map((line, lineIdx) => {\n        let cleanLine = line;\n\n        // Headers\n        if (cleanLine.startsWith(\'## \')) {\n          return <h4 key={lineIdx} className=\"text-sm font-bold tracking-tight text-neutral-100 mt-5 mb-2.5 flex items-center gap-1.5\">{cleanLine.replace(\'## \', \'\')}</h4>;\n        }\n        if (cleanLine.startsWith(\'### \')) {\n          return <h5 key={lineIdx} className=\"text-xs font-bold text-neutral-200 mt-4 mb-2\">{cleanLine.replace(\'### \', \'\')}</h5>;\n        }\n        if (cleanLine.startsWith(\'# \')) {\n          return <h3 key={lineIdx} className=\"text-md font-bold text-white mt-6 mb-3\">{cleanLine.replace(\'# \', \'\')}</h3>;\n        }\n\n        // Bullet point lists\n        const isBullet = cleanLine.startsWith(\'- \') || cleanLine.startsWith(\'* \');\n        if (isBullet) {\n          cleanLine = cleanLine.substring(2);\n        }\n\n        // Bold formatting **text**\n        const boldRegex = /\\*\\*(.*?)\\*\\*/g;\n        const parts = [];\n        let lastIndex = 0;\n        let match;\n\n        while ((match = boldRegex.exec(cleanLine)) !== null) {\n          if (match.index > lastIndex) {\n            parts.push(cleanLine.substring(lastIndex, match.index));\n          }\n          parts.push(<strong key={match.index} className=\"font-bold text-neutral-200\">{match[1]}</strong>);\n          lastIndex = boldRegex.lastIndex;\n        }\n\n        if (lastIndex < cleanLine.length) {\n          parts.push(cleanLine.substring(lastIndex));\n        }\n\n        if (isBullet) {\n          return (\n            <li key={lineIdx} className=\"ml-4 list-disc text-[11px] text-neutral-400 my-1 leading-relaxed\">\n              {parts.length > 0 ? parts : cleanLine}\n            </li>\n          );\n        }\n\n        return (\n          <p key={lineIdx} className=\"text-[11px] text-neutral-400 my-1.5 leading-relaxed min-h-[1px]\">\n            {parts.length > 0 ? parts : cleanLine}\n          </p>\n        );\n      });\n\n      return <div key={idx}>{renderedLines}</div>;\n    });\n  };\n\n  return (\n    <div className=\"flex flex-col gap-5\">\n      {/* Introduction */}\n      <div className=\"bg-neutral-900/60 p-5 rounded-3xl border border-neutral-800 backdrop-blur-sm\">\n        <div className=\"flex items-center gap-2 mb-2\">\n          <Sparkles className=\"w-4 h-4 text-yellow-400\" />\n          <h4 className=\"text-xs font-bold uppercase tracking-wider text-neutral-300\">Assistente Maker de Circuitos & C\303\263digo</h4>\n        </div>\n        <p className=\"text-neutral-400 text-xs leading-relaxed max-w-xl\">\n          Consulte o nosso assistente integrado para detalhar conex\303\265es f\303\255sicas de pinos, receber esquemas de liga\303\247\303\243o passo a passo ou requisitar l\303\263gicas espec\303\255ficas de automa\303\247\303\243o IoT prontas para o seu ESP32.\n        </p>\n\n        {/* Quick Suggest Buttons */}\n        <div className=\"flex flex-col gap-2 mt-4.5\">\n          <span className=\"text-[9.5px] font-mono text-neutral-500 uppercase tracking-wider font-bold\">Instru\303\247\303\265es R\303\241pidas Sugeridas:</span>\n          <div className=\"flex flex-wrap gap-2\">\n            {quickPrompts.map((qp, index) => (\n              <button\n                key={index}\n                onClick={() => {\n                  setPrompt(qp.text);\n                  handleAskGemini(qp.text);\n                }}\n                disabled={loading}\n                className=\"text-[10px] py-1.5 px-3 bg-neutral-950 hover:bg-neutral-900 border border-neutral-850 hover:border-neutral-700/80 rounded-xl text-neutral-400 hover:text-neutral-300 font-medium transition-all text-left disabled:opacity-50 disabled:pointer-events-none\"\n              >\n                {qp.label}\n              </button>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      {/* Workspace Prompt box */}\n      <div className=\"bg-neutral-900/60 p-5 rounded-3xl border border-neutral-800 backdrop-blur-sm flex flex-col min-h-[300px]\">\n        <div className=\"relative flex-1 flex flex-col justify-between\">\n          \n          {/* Output responses or helpers */}\n          <div className=\"flex-1 mb-5\">\n            {loading ? (\n              <div className=\"h-full min-h-[1400px: max-h-[220px]] flex flex-col items-center justify-center gap-3 py-10\">\n                <div className=\"relative h-9 w-9 rounded-full border-t-2 border-l-2 border-cyan-400 animate-spin\" />\n                <div className=\"flex flex-col items-center\">\n                  <span className=\"text-xs font-bold text-cyan-400 font-mono tracking-widest uppercase animate-pulse\">Compila\303\247\303\243o Inteligente</span>\n                  <span className=\"text-[10px] text-neutral-500 font-mono mt-1 text-center\">Consultando eletr\303\264nica do ESP32 Maker Genius...</span>\n                </div>\n              </div>\n            ) : error ? (\n              <div className=\"flex items-start gap-2.5 bg-rose-950/15 border border-rose-900/40 p-4 rounded-2xl my-4 text-rose-300\">\n                <AlertCircle className=\"w-4.5 h-4.5 flex-shrink-0 mt-0.5\" />\n                <div className=\"flex flex-col gap-0.5\">\n                  <span className=\"text-[10.5px] font-bold font-mono uppercase tracking-wider\">Falha de Inst\303\242ncia</span>\n                  <p className=\"text-[10px] leading-relaxed\">{error}</p>\n                </div>\n              </div>\n            ) : response ? (\n              <div className=\"bg-neutral-950/45 border border-neutral-850 p-5 rounded-2xl max-h-[420px] overflow-y-auto select-text shadow-inner\">\n                {renderSimpleMarkdown(response)}\n              </div>\n            ) : (\n              <div className=\"border border-dashed border-neutral-850 bg-neutral-950/10 p-8 rounded-2xl text-center flex flex-col items-center gap-2 text-neutral-500 py-10 leading-normal\">\n                <MessageSquare className=\"w-7 h-7 text-neutral-600 animate-pulse\" />\n                <span className=\"text-[11px] font-bold text-neutral-400\">Canal Livre para Chat Assist\303\252ncia</span>\n                <p className=\"text-[10px] text-neutral-500 max-w-sm\">\n                  Escreva sua d\303\272vida t\303\251cnica no campo abaixo ou selecione um dos bot\303\265es r\303\241pidos de instru\303\247\303\265es acima para acelerar o desenvolvimento.\n                </p>\n              </div>\n            )}\n          </div>\n\n          {/* Form prompts inputs */}\n          <div className=\"flex gap-2\">\n            <input \n              type=\"text\" \n              value={prompt}\n              onChange={(e) => setPrompt(e.target.value)}\n              disabled={loading}\n              placeholder=\"Perguntar sobre sensores, deep-sleep, Wi-Fi mesh..\"\n              className=\"flex-1 bg-neutral-950 border border-neutral-850 hover:border-neutral-800 text-xs px-3.5 py-3 rounded-2xl text-neutral-200 outline-none focus:border-blue-500/80 transition-all font-medium disabled:opacity-45\"\n              onKeyDown={(e) => {\n                if (e.key === \'Enter\' && prompt.trim()) {\n                  handleAskGemini(prompt);\n                }\n              }}\n            />\n            <button \n              onClick={() => handleAskGemini(prompt)}\n              disabled={loading || !prompt.trim()}\n              className=\"px-4.5 py-3 rounded-2xl bg-cyan-600 hover:bg-cyan-700 font-bold border border-cyan-500/85 text-white shadow-lg shadow-cyan-600/10 active:scale-95 transition-all text-xs flex items-center justify-center gap-1.5 disabled:opacity-45 disabled:pointer-events-none\"\n            >\n              <Send className=\"w-3.5 h-3.5\" />\n              <span>Enviar</span>\n            </button>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
