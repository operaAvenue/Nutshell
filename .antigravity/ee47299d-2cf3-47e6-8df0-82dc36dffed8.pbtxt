        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // A. Simulate Auto Blink toggles"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (pin.mode === \'DIGITAL_OUTPUT\' && pin.blinkInterval && pin.blinkInterval > 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          const expiry = pinExpiries[pin.gpio] || 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          if (now >= expiry) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            nextValue = pin.value === 0 ? 1 : 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            pinExpiries[pin.gpio] = now + pin.blinkInterval;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            changed = true;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
