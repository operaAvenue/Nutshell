  file_change {
    absolute_path_uri: "file:///src/components/ESP32Visualizer.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { LEFT_PIN_RAIL, RIGHT_PIN_RAIL } from \'../data\';\nimport { ESP32Pin, PinMode } from \'../types\';\nimport { HelpCircle, Cpu, Radio, Zap } from \'lucide-react\';\n\ninterface ESP32VisualizerProps {\n  pins: ESP32Pin[];\n  wifiMode: \'AP\' | \'STA\';\n  onSelectPin?: (gpio: number) => void;\n  selectedGpio?: number;\n}\n\nexport default function ESP32Visualizer({ pins, wifiMode, onSelectPin, selectedGpio }: ESP32VisualizerProps) {\n  const [hoveredPin, setHoveredPin] = useState<{ pin: string; desc: string } | null>(null);\n\n  // Map modes to cute colors\n  const getModeColorClass = (mode: PinMode, value: number) => {\n    switch (mode) {\n      case \'DIGITAL_OUTPUT\':\n        return value > 0 \n          ? \'bg-emerald-500 text-white ring-4 ring-emerald-400/30\' \n          : \'bg-emerald-850 border border-emerald-500/50 text-emerald-300\';\n      case \'DIGITAL_INPUT\':\n        return \'bg-amber-500 text-white ring-4 ring-amber-400/30\';\n      case \'ANALOG_INPUT\':\n        return \'bg-purple-600 text-white ring-4 ring-purple-500/30\';\n      case \'PWM_OUTPUT\':\n        return \'bg-cyan-500 text-white ring-4 ring-cyan-400/30\';\n      default:\n        return \'bg-neutral-800 text-neutral-450 hover:bg-neutral-750\';\n    }\n  };\n\n  const getPinStatus = (pinName: string) => {\n    const gpioMatch = pinName.match(/GPIO\\s+(\\d+)/);\n    if (!gpioMatch) return null;\n    const gpioNum = parseInt(gpioMatch[1], 10);\n    return pins.find(p => p.gpio === gpioNum);\n  };\n\n  return (\n    <div id=\"esp32-visual-board\" className=\"relative flex flex-col items-center select-none py-6 px-4 bg-neutral-950/70 rounded-3xl border border-neutral-800/80 backdrop-blur-md\">\n      {/* Wifi & Power Status Bar on the board */}\n      <div className=\"absolute top-4 left-6 right-6 flex justify-between text-[10px] uppercase font-mono tracking-wider text-neutral-400\">\n        <span className=\"flex items-center gap-1.5 font-bold\">\n          <span className=\"h-2 w-2 rounded-full bg-red-500 animate-pulse\" />\n          ESP32-PWR\n        </span>\n        <span className=\"flex items-center gap-1.5 font-bold\">\n          <span className=\"h-2 w-2 rounded-full bg-cyan-400\" />\n          Wi-Fi: {wifiMode === \'AP\' ? \'A.P.\' : \'STATION\'}\n        </span>\n      </div>\n\n      {/* Board Header Container with interactive helper */}\n      <div className=\"mb-4 mt-2 text-center\">\n        <h3 className=\"text-sm font-semibold tracking-wide text-neutral-200\">ESP32 DevKit V1</h3>\n        <p className=\"text-[10px] font-mono text-neutral-500 mt-0.5\">Clique em uma GPIO para configurar ou controlar</p>\n      </div>\n\n      {/* Grid containing Left Rail, Core Chip, and Right Rail */}\n      <div className=\"grid grid-cols-[140px_130px_140px] items-stretch gap-1 w-full max-w-[430px] mx-auto text-[10px] font-mono\">\n        \n        {/* LEFT RAIL */}\n        <div className=\"flex flex-col justify-between py-10 pr-2 border-r border-neutral-850/60\">\n          {LEFT_PIN_RAIL.map((item) => {\n            const status = getPinStatus(item.pin);\n            const isSelected = status && selectedGpio === status.gpio;\n            const hasGpio = item.pin.startsWith(\"GPIO\");\n            \n            return (\n              <div \n                key={item.pin} \n                className={`flex items-center justify-end gap-1.5 my-0.5 h-6 transition-all duration-150 ${hasGpio ? \'cursor-pointer\' : \'\'}`}\n                onMouseEnter={() => setHoveredPin({ pin: item.pin, desc: item.desc })}\n                onMouseLeave={() => setHoveredPin(null)}\n                onClick={() => hasGpio && status && onSelectPin && onSelectPin(status.gpio)}\n              >\n                <div className=\"text-right flex flex-col\">\n                  <span className={`font-semibold tracking-tight leading-none text-[9.5px] ${status ? \'text-neutral-200\' : \'text-neutral-500\'}`}>\n                    {status?.customLabel ? (status.customLabel.length > 12 ? status.customLabel.substring(0, 10) + \'..\' : status.customLabel) : item.pin}\n                  </span>\n                  {status && (\n                    <span className=\"text-[8px] opacity-75 text-neutral-400 mt-0.5 scale-90 origin-right\">\n                      {status.mode === \'DIGITAL_OUTPUT\' ? (status.value ? \'ON\' : \'OFF\') : \n                       status.mode === \'PWM_OUTPUT\' ? `PWM ${status.value}` :\n                       status.mode === \'ANALOG_INPUT\' ? `ADC ${status.value}` : status.mode.replace(\'_\', \' \')}\n                    </span>\n                  )}\n                </div>\n                <div className={`w-14 text-center py-1 rounded text-[8px] font-bold tracking-tighter ${\n                  isSelected ? \'ring-2 ring-blue-500 bg-blue-600/30 text-white\' : \n                  status ? getModeColorClass(status.mode, status.value) : \'bg-neutral-900 border border-neutral-800 text-neutral-500\'\n                }`}>\n                  {item.pin.replace(\"GPIO \", \"G\")}\n                </div>\n              </div>\n            );\n          })}\n        </div>\n\n        {/* CORE CHIP BODY */}\n        <div className=\"relative bg-neutral-900 rounded-xl border border-neutral-800 shadow-xl flex flex-col items-center py-4 px-2 my-2 min-h-[380px]\">\n          {/* Microcontroller CPU Module (ESP-WROOM-32) */}\n          <div className=\"w-24 bg-neutral-850 border border-neutral-750 p-2 rounded-lg flex flex-col items-center mt-3 text-neutral-400 text-center shadow-inner\">\n            <Radio className=\"w-5 h-5 text-neutral-500 animate-pulse mb-1 mt-1\" />\n            <span className=\"text-[8px] font-bold text-neutral-300\">ESP-WROOM-32</span>\n            <div className=\"w-16 h-0.5 bg-neutral-800 my-1 rounded\" />\n            <Cpu className=\"w-4 h-4 text-cyan-600/60 mb-0.5\" />\n            <span className=\"text-[6px] tracking-tight text-neutral-500 font-mono\">Dual Core 240MHz</span>\n          </div>\n\n          {/* USB Port Detail at the bottom */}\n          <div className=\"absolute bottom-0 left-1/2 -translate-x-1/2 w-10 h-7 bg-neutral-950 border-t border-x border-neutral-850 rounded-t-md flex items-center justify-center\">\n            <div className=\"w-6 h-3 bg-neutral-900 border border-neutral-850 rounded-sm flex items-center justify-center\">\n              <span className=\"text-[5px] text-neutral-600\">USB</span>\n            </div>\n          </div>\n\n          {/* Active LED Indicators */}\n          <div className=\"flex flex-col gap-2.5 items-center mt-12 w-full\">\n            {/* Built-in Blue LED (GPIO 2) status */}\n            <div className=\"flex items-center gap-1.5\">\n              <span className=\"text-[7px] text-neutral-400\">LED D2</span>\n              {(() => {\n                const ledPin = pins.find(p => p.gpio === 2);\n                const isOn = ledPin && ledPin.value > 0;\n                return (\n                  <div className={`w-2.5 h-2.5 rounded-full shadow-md transition-all duration-300 ${isOn ? \'bg-blue-500 shadow-blue-500/60 animate-pulse scale-110\' : \'bg-neutral-800\'}`} />\n                );\n              })()}\n            </div>\n\n            {/* Custom On-board red activity indicator */}\n            <div className=\"flex items-center gap-1.5\">\n              <span className=\"text-[7px] text-neutral-400 font-mono\">STATUS</span>\n              <div className=\"w-2.5 h-2.5 rounded-full bg-red-600 shadow-md animate-pulse shadow-red-500/50\" />\n            </div>\n          </div>\n\n          {/* Central Logo Accents */}\n          <div className=\"mt-8 flex flex-col items-center opacity-30 select-none\">\n            <Zap className=\"w-6 h-6 text-yellow-500\" />\n            <span className=\"text-[6px] uppercase tracking-widest text-neutral-300 font-bold mt-1\">SILI-CHIP</span>\n          </div>\n        </div>\n\n        {/* RIGHT RAIL */}\n        <div className=\"flex flex-col justify-between py-10 pl-2 border-l border-neutral-850/60\">\n          {RIGHT_PIN_RAIL.map((item) => {\n            const status = getPinStatus(item.pin);\n            const isSelected = status && selectedGpio === status.gpio;\n            const hasGpio = item.pin.startsWith(\"GPIO\");\n            \n            return (\n              <div \n                key={item.pin} \n                className={`flex items-center justify-start gap-1.5 my-0.5 h-6 transition-all duration-150 ${hasGpio ? \'cursor-pointer\' : \'\'}`}\n                onMouseEnter={() => setHoveredPin({ pin: item.pin, desc: item.desc })}\n                onMouseLeave={() => setHoveredPin(null)}\n                onClick={() => hasGpio && status && onSelectPin && onSelectPin(status.gpio)}\n              >\n                <div className={`w-14 text-center py-1 rounded text-[8px] font-bold tracking-tighter ${\n                  isSelected ? \'ring-2 ring-blue-500 bg-blue-600/30 text-white\' : \n                  status ? getModeColorClass(status.mode, status.value) : \'bg-neutral-900 border border-neutral-800 text-neutral-500\'\n                }`}>\n                  {item.pin.replace(\"GPIO \", \"G\")}\n                </div>\n                <div className=\"text-left flex flex-col\">\n                  <span className={`font-semibold tracking-tight leading-none text-[9.5px] ${status ? \'text-neutral-200\' : \'text-neutral-500\'}`}>\n                    {status?.customLabel ? (status.customLabel.length > 12 ? status.customLabel.substring(0, 10) + \'..\' : status.customLabel) : item.pin}\n                  </span>\n                  {status && (\n                    <span className=\"text-[8px] opacity-75 text-neutral-400 mt-0.5 scale-90 origin-left\">\n                      {status.mode === \'DIGITAL_OUTPUT\' ? (status.value ? \'ON\' : \'OFF\') : \n                       status.mode === \'PWM_OUTPUT\' ? `PWM ${status.value}` :\n                       status.mode === \'ANALOG_INPUT\' ? `ADC ${status.value}` : status.mode.replace(\'_\', \' \')}\n                    </span>\n                  )}\n                </div>\n              </div>\n            );\n          })}\n        </div>\n\n      </div>\n\n      {/* Floating Info Tooltip */}\n      <div className=\"mt-4 w-full text-center h-5\">\n        {hoveredPin ? (\n          <p className=\"text-[9.5px] text-cyan-400 bg-cyan-950/40 border border-cyan-900/30 py-0.5 px-3 rounded-full inline-block\">\n            <span className=\"font-bold\">{hoveredPin.pin}:</span> {hoveredPin.desc}\n          </p>\n        ) : (\n          <p className=\"text-[9.5px] text-neutral-500\">\n            Passe o mouse ou toque nos pinos para ver o diagrama de pinouts\n          </p>\n        )}\n      </div>\n\n      {/* Mode Legenda */}\n      <div className=\"flex flex-wrap justify-center gap-x-4 gap-y-1.5 mt-4 pt-3 border-t border-neutral-900 w-full text-[8.5px]\">\n        <div className=\"flex items-center gap-1 text-emerald-450\">\n          <span className=\"w-2 h-2 rounded bg-emerald-500 inline-block\" /> Output\n        </div>\n        <div className=\"flex items-center gap-1 text-amber-450\">\n          <span className=\"w-2 h-2 rounded bg-amber-500 inline-block\" /> Input\n        </div>\n        <div className=\"flex items-center gap-1 text-purple-450\">\n          <span className=\"w-2 h-2 rounded bg-purple-600 inline-block\" /> Analog (ADC)\n        </div>\n        <div className=\"flex items-center gap-1 text-cyan-450\">\n          <span className=\"w-2 h-2 rounded bg-cyan-500 inline-block\" /> PWM Reg\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
