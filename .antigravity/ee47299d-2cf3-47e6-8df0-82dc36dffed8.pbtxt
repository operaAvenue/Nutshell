}\n        {showAddForm && (\n          <form onSubmit={handleCreateNode} className=\"mt-4 p-4 rounded-2xl border border-neutral-800 bg-neutral-950/80 flex flex-col gap-3\">\n            <h5 className=\"text-[10.5px] font-bold uppercase tracking-widest text-neutral-300 font-mono\">Conectar novo ESP32</h5>\n            <div className=\"grid grid-cols-2 gap-3.5\">\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-[9px] font-mono font-bold text-neutral-400 uppercase tracking-wider\">Hostname mDNS</label>\n                <input \n                  type=\"text\" \n                  value={newHostname}\n                  onChange={(e) => setNewHostname(e.target.value)}\n                  placeholder=\"Ex: esp32-corredor\"\n                  className=\"bg-neutral-900 border border-neutral-800 text-xs px-2.5 py-2 rounded-xl text-neutral-200 outline-none focus:border-blue-500/50\"\n                  required\n                />\n              </div>\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-[9px] font-mono font-bold text-neutral-400 uppercase tracking-wider\">Ender\303\247o IP Fixo</label>\n                <input \n                  type=\"text\" \n                  value={newIp}\n                  onChange={(e) => setNewIp(e.target.value)}\n                  placeholder=\"Ex: 192.168.4.45\"\n                  className=\"bg-neutral-900 border border-neutral-800 text-xs px-2.5 py-2 rounded-xl text-neutral-200 outline-none focus:border-blue-500/50\"\n                  required\n                />\n              </div>\n            </div>\n\n            <div className=\"flex items-center justify-between mt-1\">\n              <div className=\"flex items-center gap-4\">\n                <span className=\"text-[9px] font-mono font-bold text-neutral-400 uppercase\">Fun\303\247\303\243o na Rede:</span>\n                <label className=\"flex items-center gap-1.5 cursor-pointer text-[10.5px] text-neutral-300 select-none\">\n                  <input \n                    type=\"radio\" \n                    name=\"role\" \n                    checked={newRole === \'NODE\'} \n                    onChange={() => setNewRole(\'NODE\')}\n                    className=\"accent-blue-500\" \n                  />\n                  N\303\263 Regular\n                </label>\n                <label className=\"flex items-center gap-1.5 cursor-pointer text-[10.5px] text-neutral-300 select-none\">\n                  <input \n                    type=\"radio\" \n                    name=\"role\" \n                    checked={newRole === \'COORDINATOR\'} \n                    onChange={() => setNewRole(\'COORDINATOR\')}\n                    className=\"accent-blue-500\" \n                  />\n                  Coordenador\n                </label>\n              </div>\n\n              <div className=\"flex gap-2\">\n                <button \n                  type=\"button\" \n                  onClick={() => setShowAddForm(false)}\n                  className=\"px-2.5 py-1.5 rounded-lg text-[10.5px] text-neutral-400 hover:text-neutral-200 transition-all font-mono\"\n                >\n                  Cancelar\n                </button>\n                <button \n                  type=\"submit\" \n                  className=\"bg-blue-600 border border-blue-500/70 hover:bg-blue-700 text-white font-bold px-3 py-1.5 rounded-lg text-[10.5px]\"\n                >\n                  Confirmar\n                </button>\n              </div>\n            </div>\n          </form>\n        )}\n      </div>\n\n      {/* Nodes list cards view */}\n      <div className=\"flex flex-col gap-3.5\">\n        {nodes.map((node) => {\n          return (\n            <div \n              key={node.ip} \n              className={`bg-neutral-900/60 p-4.5 rounded-3xl border transition-all ${\n                node.role === \'COORDINATOR\' \n                  ? \'border-neutral-800 border-l-4 border-l-blue-500\' \n                  : \'border-neutral-800\'\n              }`}\n            >\n              {/* Card Header information */}\n              <div className=\"flex justify-between items-start gap-2 border-b border-neutral-850 pb-3 mb-3\">\n                <div className=\"flex items-center gap-3\">\n                  <div className={`p-2.5 rounded-2xl border ${node.role === \'COORDINATOR\' ? \'bg-blue-950/40 border-blue-900/40 text-blue-400\' : \'bg-neutral-950 border-neutral-850 text-cyan-400\'}`}>\n                    <Server className=\"w-4 h-4\" />\n                  </div>\n                  <div className=\"flex flex-col\">\n                    <div className=\"flex items-center gap-1.5\">\n                      <span className=\"text-xs font-bold text-neutral-200\">{node.hostname}.local</span>\n                      <span className={`text-[8px] font-mono px-2 py-0.5 rounded-full uppercase ${node.role === \'COORDINATOR\' ? \'bg-blue-950/50 border border-blue-900/70 text-blue-400\' : \'bg-neutral-950 border border-neutral-800 text-neutral-500\'}`}>\n                        {node.role === \'COORDINATOR\' ? \'Coord / AP\' : \'N\303\263 Wifi\'}\n                      </span>\n                    </div>\n                    <span className=\"text-[10px] text-neutral-500 font-mono\">{node.ip}</span>\n                  </div>\n                </div>\n\n                <div className=\"text-right flex flex-col items-end gap-1 font-mono text-[9.5px]\">\n                  <div className=\"flex items-center gap-1.5\">\n                    <Wifi className={`w-3.5 h-3.5 ${getRssiColor(node.rssi)}`} />\n                    <span className={`font-bold ${getRssiColor(node.rssi)}`}>{node.rssi} dBm</span>\n                  </div>\n                  <span className=\"text-[8px] text-neutral-500\">Sinal: {getRssiLabel(node.rssi)}</span>\n                </div>\n              </div>\n\n              {/* Node Remote Pin Controllers */}\n   