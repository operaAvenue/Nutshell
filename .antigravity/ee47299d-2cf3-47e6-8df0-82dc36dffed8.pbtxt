          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    ${pins.filter(p => p.mode !== \'UNUSED\').map(p => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const isOutput = p.mode === \'DIGITAL_OUTPUT\';"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const isInput = p.mode === \'DIGITAL_INPUT\';"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const isAnalog = p.mode === \'ANALOG_INPUT\';"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
