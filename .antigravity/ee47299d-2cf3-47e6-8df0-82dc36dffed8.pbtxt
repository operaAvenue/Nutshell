    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { INITIAL_PINS, INITIAL_NODES, DEFAULT_WIFI_SETTINGS } from \'./data\';\nimport { ESP32Pin, ESP32Node, WiFiSettings, SerialLog } from \'./types\';\nimport ESP32Visualizer from \'./components/ESP32Visualizer\';\nimport PinController from \'./components/PinController\';\nimport NodeMonitor from \'./components/NodeMonitor\';\nimport FirmwareExporter from \'./components/FirmwareExporter\';\nimport AiAssistant from \'./components/AiAssistant\';\nimport LogConsole from \'./components/LogConsole\';\nimport { \n  Sliders, \n  Layers, \n  FileCode, \n  Sparkles, \n  Settings, \n  Wifi, \n  Radio, \n  Cpu, \n  Minimize2, \n  Maximize2,\n  ChevronRight,\n  Tv\n} from \'lucide-react\';\n\nexport default function App() {\n  // Core application States\n  const [pins, setPins] = useState<ESP32Pin[]>(INITIAL_PINS);\n  const [selectedGpio, setSelectedGpio] = useState<number>(2); // Default to internal Pin 2\n  const [wifiSettings, setWifiSettings] = useState<WiFiSettings>(DEFAULT_WIFI_SETTINGS);\n  const [nodes, setNodes] = useState<ESP32Node[]>(INITIAL_NODES);\n  const [activeTab, setActiveTab] = useState<\'CONTROLS\' | \'MESH\' | \'FIRMWARE\' | \'AI_ASSIST\'>(\'CONTROLS\');\n  const [isFullscreen, setIsFullscreen] = useState<boolean>(false); // Desktop view vs mobile frame\n  \n  // Simulated logs buffer\n  const [logs, setLogs] = useState<SerialLog[]>([\n    { timestamp: \"00:00:01\", source: \"SYSTEM\", message: \"Inicializando ESP32 Core chipset...\" },\n    { timestamp: \"00:00:02\", source: \"SYSTEM\", message: \"CPU clock regulado para o m\303\241ximo: 240 MHz (Dual Core)\" },\n    { timestamp: \"00:00:03\", source: \"GPIO\", message: \"Registrados controladores GPIO nativos do mapa DevKit V1\" },\n    { timestamp: \"00:00:04\", source: \"WIFI\", message: \"mDNS registrador preparado em http://esp32-controller.local\" },\n    { timestamp: \"00:00:05\", source: \"WIFI\", message: \"Inicializando ponto de acesso local: [ESP32_Controler_P2P]\" },\n    { timestamp: \"00:00:06\", source: \"HTTP\", message: \"Servidor Web HTTP ativo na porta 80. Respondendo endpoints REST\" }\n  ]);\n\n  // Helper to push a new row to Console logs with proper timestamp formatting\n  const addLog = (source: \'SYSTEM\' | \'WIFI\' | \'HTTP\' | \'GPIO\' | \'ERROR\', message: string) => {\n    const now = new Date();\n    const timeFormatted = now.toTimeString().split(\' \')[0];\n    setLogs(prev => [...prev, { timestamp: timeFormatted, source, message }]);\n  };\n\n  const handleClearLogs = () => {\n    setLogs([]);\n    addLog(\'SYSTEM\', \'Log de console resetado pelo usu\303\241rio.\');\n  };\n\n  // Find the currently focused pin\n  const selectedPin = pins.find(p => p.gpio === selectedGpio) || pins[0];\n\n  // Callback to update a pin state\n  const handleUpdatePin = (updatedPin: ESP32Pin) => {\n    setPins(prev => prev.map(p => p.gpio === updatedPin.gpio ? updatedPin : p));\n  };\n\n  const handleSelectPinByGpio = (gpio: number) => {\n    setSelectedGpio(gpio);\n  };\n\n  // Add peer node manually\n  const handleAddNode = (newNode: ESP32Node) => {\n    setNodes(prev => {\n      // Avoid duplicate IPs\n      if (prev.some(n => n.ip === newNode.ip)) return prev;\n      return [...prev, newNode];\n    });\n  };\n\n  // Toggle state of a remote node pin\n  const handleUpdateNodePin = (nodeIp: string, gpio: number, newValue: number) => {\n    setNodes(prev => prev.map(node => {\n      if (node.ip === nodeIp) {\n        return {\n          ...node,\n          pinStates: {\n            ...node.pinStates,\n            [gpio]: {\n              ...node.pinStates[gpio],\n              value: newValue\n            }\n          },\n          lastSeen: \"Agora mesmo\"\n        };\n      }\n      return node;\n    }));\n  };\n\n  // 1. Simulation Loop: Dynamic blink and Analog fluctuates\n  useEffect(() => {\n    // Keep track of accumulated times for each pin\'s blink cycle\n    const pinExpiries: { [gpio: number]: number } = {};\n    pins.forEach(pin => {\n      if (pin.blinkInterval && pin.blinkInterval > 0) {\n        pinExpiries[pin.gpio] = Date.now() + pin.blinkInterval;\n      }\n    });\n\n    const simTimer = setInterval(() => {\n      const now = Date.now();\n      let updatedAny = false;\n\n      const nextPins = pins.map(pin => {\n        let changed = false;\n        let nextValue = pin.value;\n\n        // A. Simulate Auto Blink toggles\n        if (pin.mode === \'DIGITAL_OUTPUT\' && pin.blinkInterval && pin.blinkInterval > 0) {\n          const expiry = pinExpiries[pin.gpio] || 0;\n          if (now >= expiry) {\n            nextValue = pin.value === 0 ? 1 : 0;\n            pinExpiries[pin.gpio] = now + pin.blinkInterval;\n            changed = true;\n          }\n        }\n\n        // B. Simulate Analog ADC Fluctuation\n        if (pin.mode === \'ANALOG_INPUT\') {\n          // slight fluctuation, standard ADC maximum range is 4095\n          const delta = Math.floor(Math.random() * 41) - 20; // fluctuate +/- 20\n          nextValue = Math.max(0, Math.min(4095, pin.value + delta));\n          changed = true;\n        }\n\n        if (changed) {\n          updatedAny = true;\n          return { ...pin, value: nextValue };\n        }\n        return pin;\n      });\n\n      if (updatedAny) {\n        setPins(nextPins);\n      }\n    }, 300); // Poll fast for smooth visual feedback\n\n    return () => clearInterval(simTimer);\n  }, [pins]);\n\n  // WiFi mode toggle with logging simulator\n  const toggleWifiMode = () => {\n    const nextMode = wifiSettings.mode === \'AP\' ? \'STA\' : \'AP\';\n    setWifiSettings(prev => ({ ...prev, mode: nextMode }));\n    \n    addLog(\'WIFI\', `Modo de rede alternado para [${nextMode === \'AP\' ? \'PONTO DE ACESSO (AP)\' : \'ESTA\303\207\303\203O ROTEADOR (STA)\'}]`);\n    \n    if (nextMode === \'STA\') {\n      addLog(\'WIFI\', `Requisitando endere\303\247o IP est\303\241tico ao Servidor DHCP...`);\n      setTimeout(() => {\n        addLog(\'WIFI\', `Wi-Fi Conectado ao Gateway! IP atribu\303\255do: ${wifiSettings.staIp}`);\n        addLog(\'HTTP\', `mDNS atualizado: Controle dispon\303\255vel em http://esp32-controller.local`);\n      }, 1000);\n    } else {\n      addLog(\'WIFI\', `Rede P2P Wi-Fi configurada no IP Padr\303\243o: ${wifiSettings.apIp}`);\n    }\n  };\n\n  return (\n    <div id=\"main-panel\" className=\"min-h-screen bg-neutral-950 text-neutral-100 font-sans flex flex-col justify-between antialiased\">\n      \n      {/* BACKGROUND AMBIENT DETAILS */}\n      <div className=\"absolute top-0 left-0 right-0 h-[500px] bg-gradient-to-b from-blue-900/10 via-cyan-900/5 to-transparent pointer-events-none select-none\" />\n\n      {/* HEADER BAR */}\n      <header className=\"relative border-b border-neutral-900/80 bg-neutral-950/80 backdrop-blur-md px-6 py-4.5 flex justify-between items-center z-20\">\n        <div className=\"flex items-center gap-2.5\">\n          <div className=\"p-2 border border-cyan-500/20 bg-cyan-600/10 text-cyan-400 rounded-2xl\">\n            <Cpu className=\"w-5 h-5 animate-pulse\" />\n          </div>\n          <div>\n            <h1 className=\"text-sm font-bold tracking-tight text-white flex items-center gap-1.5\">\n              ESP32 IoT Dashboard\n              <span className=\"text-[9px] font-mono tracking-widest font-normal text-cyan-400/80 bg-cyan-950/40 border border-cyan-900/40 px-2 py-0.5 rounded-full select-none animate-pulse\">v2.5_STA</span>\n            </h1>\n            <p className=\"text-[10px] font-mono text-neutral-500 mt-0.5\">Controlador Wi-Fi nativo de alta efici\303\252ncia</p>\n          </div>\n        </div>\n\n        {/* Dynamic network indicators */}\n        <div className=\"flex items-center gap-3.5\">\n          <div className=\"hidden sm:flex items-center gap-2 bg-neutral-900/40 border border-neutral-850 py-1.5 px-3.5 rounded-2xl font-mono text-[9.5px] select-none text-neutral-400\">\n            <Radio className=\"w-3.5 h-3.5 text-neutral-500\" />\n            <span>Pino selecionado: </span>\n            <span className=\"font-bold text-cyan-400\">G{selectedPin.gpio}</span>\n          </div>\n\n          {/* Quick toggle between mobile viewer frame & responsive layout */}\n          <button \n            type=\"button\"\n            onClick={() => setIsFullscreen(!isFullscreen)}\n            className=\"flex items-center gap-1.5 px-3 py-2 bg-neutral-900 hover:bg-neutral-850 hover:text-white rounded-2xl text-[10.5px] font-bold border border-neutral-850 text-neutral-400 transition-all active:scale-95 cursor-pointer select-none\"\n            title=\"Alternar entre visualiza\303\247\303\243o de smartphone ou ocupar tela toda\"\n          >\n            <Tv className=\"w-3.5 h-3.5\" />\n            <span className=\"hidden sm:inline\">{isFullscreen ? \'Smartphone Frame\' : \'Full Screen\'}</span>\n          </button>\n        </div>\n      </header>\n\n      {/* CORE WORKSPACE container (Centering with device mockup if in Full Screen) */}\n      <main className=\"flex-1 relative z-10 px-4 sm:px-6 py-6 max-w-7xl mx-auto w-full flex flex-col justify-start\">\n        \n        {/* Device frame container IF isFullscreen is active */}\n        <div className={`transition-all duration-300 w-full ${isFullscreen ? \'\' : \'max-w-[480px] mx-auto bg-neutral-900/40 border border-neutral-850 p-5 rounded-[40px] shadow-2xl relative\'}`}>\n          \n          {/* Smart Phone details */}\n          {!isFullscreen && (\n            <div className=\"absolute top-2.5 left-1/2 -translate-x-1/2 w-32 h-4.5 bg-neutral-950 border border-neutral-850 rounded-full flex justify-center items-center select-none z-30 pointer-events-none\">\n              <span className=\"h-1.5 w-1.5 rounded-full bg-blue-600 mr-2\" />\n              <span className=\"h-1 w-12 rounded-full bg-neutral-800\" />\n            </div>\n          )}\n\n          <div className={`${isFullscreen ? \'\' : \'pt-7\'}`}>\n            \n            {/* NETWORK BANNER */}\n            <div className=\"bg-neutral-900/70 py-4 px-5 rounded-3xl border border-neutral-800/80 mb-5 flex items-center justify-between shadow-xl\">\n              <div className=\"flex items-center gap-3\">\n                <div onClick={toggleWifiMode} className={`p-2.5 rounded-2xl cursor-pointer border select-none transition-all ${\n                  wifiSettings.mode === \'AP\' \n                    ? \'bg-emerald-950/40 border-emerald-900/50 text-emerald-400 hover:bg-emerald-950\' \n                    : \'bg-blue-950/40 border-blue-900/50 text-blue-400 hover:bg-blue-950\'\n                }`}>\n                  <Wifi className=\"w-5 h-5 animate-pulse\" />\n                </div>\n                <div className=\"flex flex-col select-all\">\n                  <span className=\"text-xs font-bold text-neutral-200\">\n                    SSID: {wifiSettings.mode === \'AP\' ? wifiSettings.apSsid : wifiSettings.ssid}\n                  </span>\n                  <span className=\"text-[10px] font-mono text-neutral-500 mt-0.5\">\n                    Endere\303\247o IP: <strong className=\"text-cyan-400 font-bold\">{wifiSettings.mode === \'AP\' ? wifiSettings.apIp : wifiSettings.staIp}</strong>\n                  </span>\n                </div>\n              </div>\n\n              <div className=\"flex flex-col items-end\">\n                <button \n                  onClick={toggleWifiMode}\n                  className=\"text-[9.5px] font-bold text-neutral-400 hover:text-white uppercase tracking-wider font-mono cursor-pointer py-1 px-3 bg-neutral-950 border border-neutral-850 rounded-xl\"\n                >\n                  Reg: {wifiSettings.mode}\n                </button>\n              </div>\n            </div>\n\n            {/* TAB SELECTOR NAV */}\n            <nav className=\"grid grid-cols-4 gap-1 p-1 bg-neutral-950 rounded-2xl border border-neutral-900 mb-5 select-none\">\n              <button \n                onClick={() => setActiveTab(\'CONTROLS\')}\n                className={`py-2 px-1 rounded-xl flex flex-col items-center gap-1 transition-all cursor-pointer ${\n                  activeTab === \'CONTROLS\' \n                    ? \'bg-blue-600 text-white font-bold\' \n                    : \'text-neutral-550 hover:text-neutral-300\'\n                }`}\n              >\n                <Sliders className=\"w-4 h-4\" />\n                <span className=\"text-[8.5px] font-mono whitespace-nowrap\">Dashboard</span>\n              </button>\n              \n              <button \n                onClick={() => setActiveTab(\'MESH\')}\n                className={`py-2 px-1 rounded-xl flex flex-col items-center gap-1 transition-all cursor-pointer ${\n                  activeTab === \'MESH\' \n                    ? \'bg-blue-600 text-white font-bold\' \n                    : \'text-neutral-555 hover:text-neutral-300\'\n                }`}\n              >\n                <Layers className=\"w-4 h-4\" />\n                <span className=\"text-[8.5px] font-mono whitespace-nowrap\">Malha</span>\n              </button>\n              \n              <button \n                onClick={() => setActiveTab(\'FIRMWARE\')}\n                className={`py-2 px-1 rounded-xl flex flex-col items-center gap-1 transition-all cursor-pointer ${\n                  activeTab === \'FIRMWARE\' \n                    ? \'bg-blue-600 text-white font-bold\' \n                    : \'text-neutral-555 hover:text-neutral-300\'\n                }`}\n              >\n                <FileCode className=\"w-4 h-4\" />\n                <span className=\"text-[8.5px] font-mono whitespace-nowrap\">C++ Code</span>\n              </button>\n\n              <button \n                onClick={() => setActiveTab(\'AI_ASSIST\')}\n                className={`py-2 px-1 rounded-xl flex flex-col items-center gap-1 transition-all cursor-pointer ${\n                  activeTab === \'AI_ASSIST\' \n                    ? \'bg-blue-600 text-white font-bold\' \n                    : \'text-neutral-555 hover:text-neutral-300\'\n                }`}\n              >\n                <Sparkles className=\"w-4 h-4\" />\n                <span className=\"text-[8.5px] font-mono whitespace-nowrap\">Maker IA</span>\n              </button>\n            </nav>\n\n            {/* MAIN TAB SWITCHBOARD */}\n            <div id=\"tab-content-frame\" className=\"min-h-[460px] flex flex-col justify-start\">\n              {activeTab === \'CONTROLS\' && (\n                <div className={`grid gap-5 ${isFullscreen ? \'grid-cols-1 lg:grid-cols-2\' : \'grid-cols-1\'}`}>\n                  \n                  {/* Left Column: Visual Map */}\n                  <div className=\"flex flex-col\">\n                    <ESP32Visualizer \n                      pins={pins}\n                      wifiMode={wifiSettings.mode}\n                      selectedGpio={selectedGpio}\n                      onSelectPin={handleSelectPinByGpio}\n                    />\n                  </div>\n\n                  {/* Right Column: Hardware Controllers */}\n                  <div className=\"flex flex-col\">\n                    <PinController \n                      pins={pins}\n                      selectedPin={selectedPin}\n                      onUpdatePin={handleUpdatePin}\n                      onSelectPinByGpio={handleSelectPinByGpio}\n                      onAddLog={addLog}\n                    />\n                  </div>\n\n                </div>\n              )}\n\n              {activeTab === \'MESH\' && (\n                <NodeMonitor \n                  nodes={nodes}\n                  onAddNode={handleAddNode}\n                  onUpdateNodePin={handleUpdateNodePin}\n                  onAddLog={addLog}\n                />\n              )}\n\n              {activeTab === \'FIRMWARE\' && (\n                <FirmwareExporter \n                  pins={pins}\n                  wifiSettings={wifiSettings}\n                  onAddLog={addLog}\n                />\n              )}\n\n              {activeTab === \'AI_ASSIST\' && (\n                <AiAssistant \n                  onAddLog={addLog}\n                />\n              )}\n            </div>\n\n          </div>\n        </div>\n\n        {/* RECT SERIAL LOGGER BOX AT THE VERY FOOTER OF DETAILED WORKSPACE */}\n        <div className=\"mt-8.0 w-full\">\n          <LogConsole \n            logs={logs}\n            onClearLogs={handleClearLogs}\n            onAddLog={addLog}\n          />\n        </div>\n\n      </main>\n\n      {/* FOOTER */}\n      <footer className=\"relative bg-neutral-950 border-t border-neutral-900 py-4 px-6 text-center select-none z-20\">\n        <p className=\"text-[9.5px] font-mono text-neutral-600 leading-normal\">\n          Designed for <strong className=\"text-neutral-500\">NodeMCU & ESP32-WROOM-32</strong> | Direct LAN Server Serviced\n        </p>\n        <p className=\"text-[8px] font-mono text-neutral-700 mt-1\">\n          \302\251 2026 ESP32 Control Group\n        </p>\n      </footer>\n\n    </div>\n  );\n}\n"
    }
