      replacement_content: "import React, { useState } from \'react\';\nimport { ESP32Pin, PinMode } from \'../types\';\nimport { ToggleLeft, ToggleRight, RotateCcw, Sliders, Activity, Info, Tag, Bolt } from \'lucide-react\';\n\ninterface PinControllerProps {\n  pins: ESP32Pin[];\n  selectedPin: ESP32Pin;\n  onUpdatePin: (updatedPin: ESP32Pin) => void;\n  onSelectPinByGpio: (gpio: number) => void;\n  onAddLog: (source: \'SYSTEM\' | \'WIFI\' | \'HTTP\' | \'GPIO\' | \'ERROR\', message: string) => void;\n}\n\nexport default function PinController({ pins, selectedPin, onUpdatePin, onSelectPinByGpio, onAddLog }: PinControllerProps) {\n  // Local state to manage toggle values for quick simulation\n  const [isFluctuating, setIsFluctuating] = useState<boolean>(true);\n\n  const handleModeChange = (e: React.ChangeEvent<HTMLSelectElement>) => {\n    const newMode = e.target.value as PinMode;\n    let defValue = 0;\n    if (newMode === \'PWM_OUTPUT\') defValue = 128; // Default half brightness\n    if (newMode === \'ANALOG_INPUT\') defValue = 2048; // Default half scale\n\n    const updated: ESP32Pin = {\n      ...selectedPin,\n      mode: newMode,\n      value: defValue,\n      blinkInterval: 0\n    };\n\n    onUpdatePin(updated);\n    onAddLog(\'GPIO\', `Configurado GPIO ${selectedPin.gpio} para o modo [${newMode.replace(\'_\', \' \')}]`);\n  };\n\n  const handleLabelChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    onUpdatePin({\n      ...selectedPin,\n      customLabel: e.target.value\n    });\n  };\n\n  const handleToggleDigitalValue = () => {\n    const newValue = selectedPin.value === 0 ? 1 : 0;\n    onUpdatePin({\n      ...selectedPin,\n      value: newValue\n    });\n    onAddLog(\'GPIO\', `GPIO ${selectedPin.gpio} (${selectedPin.customLabel || selectedPin.name}) ajustado para [${newValue === 1 ? \'LIGADO\' : \'DESLIGADO\'}]`);\n    \n    // Simulate hitting simulated local Web server\n    fetch(`/api/toggle?pin=${selectedPin.gpio}&val=${newValue}`)\n      .catch(() => {}); // Eat error silently in purely client load\n  };\n\n  const handlePwmChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    const val = parseInt(e.target.value, 10);\n    onUpdatePin({\n      ...selectedPin,\n      value: val\n    });\n  };\n\n  const handlePwmRelease = () => {\n    onAddLog(\'GPIO\', `GPIO ${selectedPin.gpio} PWM ajustado para ${selectedPin.value}`);\n  };\n\n  const handleAnalogChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    const val = parseInt(e.target.value, 10);\n    onUpdatePin({\n      ...selectedPin,\n      value: val\n    });\n  };\n\n  const handleDigitalInputToggle = () => {\n    const newVal = selectedPin.value === 0 ? 1 : 0;\n    onUpdatePin({\n      ...selectedPin,\n      value: newVal\n    });\n    onAddLog(\'GPIO\', `Simula\303\247\303\243o de Entrada Digital GPIO ${selectedPin.gpio} -> [${newVal === 1 ? \'ALTO\' : \'BAIXO\'}]`);\n  };\n\n  return (\n    <div className=\"flex flex-col gap-5 h-full\">\n      {/* SECTION 1: Active Pins Quick Switch Board */}\n      <div id=\"quick-controls\" className=\"bg-neutral-900/60 p-5 rounded-3xl border border-neutral-800 backdrop-blur-sm\">\n        <div className=\"flex items-center gap-2 mb-3.5\">\n          <Bolt className=\"w-4 h-4 text-emerald-400\" />\n          <h4 className=\"text-xs font-bold uppercase tracking-wider text-neutral-300\">Controles R\303\241pidos</h4>\n        </div>\n\n        <div className=\"grid grid-cols-2 gap-2.5 max-h-[160px] overflow-y-auto pr-1\">\n          {pins.filter(p => p.mode !== \'UNUSED\').length === 0 ? (\n            <div className=\"col-span-2 text-center py-6 text-neutral-500 text-xs\">\n              Nenhuma GPIO em uso. Selecione um pino no ESP32 para configur\303\241-lo.\n            </div>\n          ) : (\n            pins.filter(p => p.mode !== \'UNUSED\').map(pin => {\n              const isSelected = selectedPin.gpio === pin.gpio;\n              return (\n                <div \n                  key={pin.gpio} \n                  onClick={() => onSelectPinByGpio(pin.gpio)}\n                  className={`flex items-center justify-between p-2.5 rounded-2xl cursor-pointer text-xs border transition-all ${\n                    isSelected \n                      ? \'bg-blue-600/10 border-blue-500/50 text-white\' \n                      : \'bg-neutral-950/40 border-neutral-850 text-neutral-400 hover:border-neutral-700/80\'\n                  }`}\n                >\n                  <div className=\"truncate flex flex-col gap-0.5 justify-center min-w-0 pr-1.5\">\n                    <span className=\"font-semibold truncate text-[11px]\">\n                      {pin.customLabel || pin.name}\n                    </span>\n                    <span className=\"text-[9px] font-mono opacity-65 scale-90 origin-left\">\n                      G{pin.gpio} \342\200\242 {pin.mode === \'DIGITAL_OUTPUT\' ? \'OUT\' : pin.mode === \'PWM_OUTPUT\' ? \'PWM\' : pin.mode === \'ANALOG_INPUT\' ? \'ADC\' : \'IN\'}\n                    </span>\n                  </div>\n\n                  {/* Quick Control Toggle/Output state display */}\n                  <div onClick={(e) => { e.stopPropagation(); onSelectPinByGpio(pin.gpio); }} className=\"flex-shrink-0\">\n                    {pin.mode === \'DIGITAL_OUTPUT\' && (\n                      <button \n                        onClick={(e) => {\n                          e.stopPropagation();\n                          const newValue = pin.value === 0 ? 1 : 0;\n                          onUpdatePin({ ...pin, value: newValue });\n                          onAddLog(\'GPIO\', `GPIO ${pin.gpio} (${pin.customLabel}) alternado para [${newValue ? \'ON\' : \'OFF\'}]`);\n                        }}\n                        className={`p-1.5 rounded-full transition-all ${pin.value === 1 ? \'text-emerald-400 bg-emerald-950/50\' : \'text-neutral-500 hover:text-neutral-300\'}`}\n                      >\n                        {pin.value === 1 ? <ToggleRight className=\"w-5 h-5\" /> : <ToggleLeft className=\"w-5 h-5\" />}\n                      </button>\n                    )}\n                    {pin.mode === \'PWM_OUTPUT\' && (\n                      <span className=\"bg-cyan-950/40 border border-cyan-900/35 text-cyan-400 text-[9px] py-0.5 px-2 rounded-full font-mono\">\n                        {Math.round((pin.value / 255) * 100)}%\n                      </span>\n                    )}\n                    {pin.mode === \'ANALOG_INPUT\' && (\n                      <span className=\"bg-purple-950/40 border border-purple-900/35 text-purple-400 text-[9px] py-0.5 px-2 rounded-full font-mono animate-pulse\">\n                        {pin.value}\n                      </span>\n                    )}\n                    {pin.mode === \'DIGITAL_INPUT\' && (\n                      <span className={`px-2 py-0.5 text-[9px] font-mono rounded-full border ${\n                        pin.value === 1 \n                          ? \'bg-amber-950/40 border-amber-900/50 text-amber-400 font-bold\' \n                          : \'bg-neutral-950 border-neutral-800 text-neutral-500\'\n                      }`}>\n                        {pin.value === 1 ? \'HIGH\' : \'LOW\'}\n                      </span>\n                    )}\n                  </div>\n                </div>\n              );\n            })\n          )}\n        </div>\n      </div>\n\n      {/* SECTION 2: GPIO Settings Panel */}\n      <div id=\"pin-settings\" className=\"bg-neutral-900/60 p-5 rounded-3xl border border-neutral-800 backdrop-blur-sm flex-1 flex flex-col justify-between\">\n        <div>\n          <div className=\"flex items-center justify-between mb-4 pb-3 border-b border-neutral-850\">\n            <div className=\"flex items-center gap-2\">\n              <Sliders className=\"w-4 h-4 text-blue-400\" />\n              <h4 className=\"text-xs font-bold uppercase tracking-wider text-neutral-300\">Ajuste de GPIO</h4>\n            </div>\n            <span className=\"font-mono text-[10px] bg-neutral-950 px-2.5 py-1 rounded-full border border-neutral-800 text-cyan-400 font-bold\">\n              {selectedPin.name}\n            </span>\n          </div>\n\n          <div className=\"flex flex-col gap-4\">\n            {/* PIN MODE SELECTION */}\n            <div className=\"flex flex-col gap-1.5\">\n              <label className=\"text-[10px] font-bold uppercase tracking-wider text-neutral-400 font-mono flex items-center gap-1.5\">\n                <Info className=\"w-3.5 h-3.5\" /> Modo de Opera\303\247\303\243o\n              </label>\n              <select \n                value={selectedPin.mode} \n                onChange={handleModeChange}\n                className=\"w-full bg-neutral-950 border border-neutral-800 hover:border-neutral-700/80 text-xs px-3 py-2.5 rounded-2xl text-neutral-200 outline-none focus:border-blue-500/80 transition-all cursor-pointer font-medium\"\n              >\n                <option value=\"UNUSED\">N\303\243o Selecionado (Inativo)</option>\n                <option value=\"DIGITAL_OUTPUT\">Sa\303\255da Digital (Controle Lig/Desl)</option>\n                <option value=\"DIGITAL_INPUT\">Entrada Digital (Leitura Sensores/Bot\303\243o)</option>\n                <option value=\"ANALOG_INPUT\">Entrada Anal\303\263gica (Sensor ADC1)</option>\n                <option value=\"PWM_OUTPUT\">Sa\303\255da PWM (Dimmer / Motor / Fita LED)</option>\n              </select>\n            </div>\n\n            {/* PIN CUSTOM LABEL */}\n            <div className=\"flex flex-col gap-1.5\">\n              <label className=\"text-[10px] font-bold uppercase tracking-wider text-neutral-400 font-mono flex items-center gap-1.5\">\n                <Tag className=\"w-3.5 h-3.5\" /> Etiqueta Personalizada\n              </label>\n              <div className=\"relative\">\n                <input \n                  type=\"text\" \n                  value={selectedPin.customLabel} \n                  onChange={handleLabelChange}\n                  disabled={selectedPin.mode === \'UNUSED\'}\n                  placeholder=\"Ex: Sensor de Solo, LED Sala..\"\n                  className=\"w-full bg-neutral-950 border border-neutral-800 hover:border-neutral-700 text-xs pl-3 pr-8 py-2.5 rounded-2xl text-neutral-200 outline-none focus:border-blue-500/80 transition-all disabled:opacity-45 disabled:pointer-events-none font-medium\"\n                />\n                <span className=\"absolute right-3 top-1/2 -translate-y-1/2 text-neutral-600 pointer-events-none text-[11px] font-mono\">\n                  G{selectedPin.gpio}\n                </span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* SECTION 3: Dynamic Interactors based on selected mode */}\n        <div className=\"mt-6 pt-5 border-t border-neutral-850\">\n          {selectedPin.mode === \'UNUSED\' && (\n            <div className=\"text-center py-6 px-4 bg-neutral-950/20 rounded-2xl border border-dashed border-neutral-850\">\n              <p className=\"text-[11px] text-neutral-400 leading-normal\">\n                Este pino est\303\241 <span className=\"text-neutral-500 font-bold\">Inativo</span> no momento.\n              </p>\n              <p className=\"text-[9.5px] text-neutral-500 mt-1\">\n                Altere o modo acima para come\303\247ar a monitorar ou controlar\n              </p>\n            </div>\n          )}\n\n          {selectedPin.mode === \'DIGITAL_OUTPUT\' && (\n            <div className=\"flex flex-col gap-3.5\">\n              <div className=\"flex items-center justify-between bg-neutral-950/30 p-3.5 rounded-2xl border border-neutral-850/80\">\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[11px] font-bold text-neutral-200\">Estado Local do Pino</span>\n                  <span className=\"text-[9.5px] text-neutral-500\">Valor enviado ao pino f\303\255sico</span>\n                </div>\n                <button \n                  onClick={handleToggleDigitalValue}\n                  className={`flex items-center gap-1.5 px-4 py-2 rounded-xl text-xs font-bold tracking-tight transition-all shadow-md ${\n                    selectedPin.value === 1 \n                      ? \'bg-emerald-500 text-white shadow-emerald-500/20 active:bg-emerald-600\' \n                      : \'bg-neutral-800 text-neutral-300 hover:bg-neutral-750\'\n                  }`}\n                >\n                  <span className={`w-1.5 h-1.5 rounded-full ${selectedPin.value === 1 ? \'bg-white animate-ping\' : \'bg-neutral-500\'}`} />\n                  {selectedPin.value === 1 ? \'LIGADO (HIGH)\' : \'DESLIGADO (LOW)\'}\n                </button>\n              </div>\n\n              {/* Blink setting */}\n              <div className=\"flex flex-col gap-1.5 bg-neutral-950/20 p-3 rounded-2xl border border-neutral-850/60\">\n                <div className=\"flex justify-between items-center text-[10px] font-mono\">\n                  <span className=\"text-neutral-400 uppercase tracking-widest font-bold\">Simular Piscar</span>\n                  <span className=\"text-blue-400 font-bold\">\n                    {selectedPin.blinkInterval ? `${selectedPin.blinkInterval}ms` : \'Inativo\'}\n                  </span>\n                </div>\n                <input \n                  type=\"range\"\n                  min=\"0\"\n                  max=\"3000\"\n                  step=\"100\"\n                  value={selectedPin.blinkInterval || 0}\n                  onChange={(e) => {\n                    const int = parseInt(e.target.value, 10);\n                    onUpdatePin({\n                      ...selectedPin,\n                      blinkInterval: int\n                    });\n                    if (int > 0) {\n                      onAddLog(\'GPIO\', `Ativado auto-blink em GPIO ${selectedPin.gpio} a cada ${int}ms`);\n                    } else {\n                      onAddLog(\'GPIO\', `Desativado auto-blink em GPIO ${selectedPin.gpio}`);\n                    }\n                  }}\n                  className=\"w-full accent-blue-500 cursor-pointer h-1.5 bg-neutral-800 rounded-lg appearance-none mt-1\"\n                />\n                <p className=\"text-[8px] text-neutral-500 font-mono scale-95 origin-left leading-normal\">\n                  Configura uma altern\303\242ncia autom\303\241tica de estado para simular clock ou timer.\n                </p>\n              </div>\n            </div>\n          )}\n\n          {selectedPin.mode === \'DIGITAL_INPUT\' && (\n            <div className=\"bg-neutral-950/30 p-4 rounded-2xl border border-neutral-850/80 flex items-center justify-between\">\n              <div className=\"flex flex-col gap-0.5\">\n                <span className=\"text-[11px] font-bold text-neutral-200\">Simula\303\247\303\243o de Entrada</span>\n                <span className=\"text-[9.5px] text-neutral-500\">Pressione para simular sinal HIGH</span>\n              </div>\n              <button \n                onClick={handleDigitalInputToggle}\n                className={`py-2 px-4 rounded-xl text-xs font-bold tracking-tight border transition-all ${\n                  selectedPin.value === 1 \n                    ? \'bg-amber-500 border-amber-400 text-white shadow-lg shadow-amber-500/20\' \n                    : \'bg-neutral-950 border-neutral-800 text-neutral-400\'\n                }`}\n              >\n                {selectedPin.value === 1 ? \'ALTO (HIGH)\' : \'BAIXO (LOW)\'}\n              </button>\n            </div>\n          )}\n\n          {selectedPin.mode === \'ANALOG_INPUT\' && (\n            <div className=\"flex flex-col gap-3.5\">\n              <div className=\"bg-neutral-950/30 p-3.5 rounded-2xl border border-neutral-850/85\">\n                <div className=\"flex justify-between items-center mb-1 font-mono text-[10px]\">\n                  <span className=\"text-neutral-400 uppercase tracking-widest font-bold flex items-center gap-1\">\n                    <Activity className=\"w-3.5 h-3.5 text-purple-400\" /> Leitura ADC (12-bit)\n                  </span>\n                  <span className=\"text-purple-400 font-bold\">{selectedPin.value} / 4095</span>\n                </div>\n\n                {/* Progress bar visualizer */}\n                <div className=\"w-full h-3 bg-neutral-950 rounded-full overflow-hidden border border-neutral-850/60 p-[1.5px] mt-2\">\n                  <div \n                    style={{ width: `${(selectedPin.value / 4095) * 100}%` }}\n                    className=\"h-full bg-gradient-to-r from-purple-600 to-indigo-500 rounded-full transition-all duration-300\"\n                  />\n                </div>\n\n                {/* Volts Indicator */}\n                <div className=\"flex justify-between items-center text-[9px] font-mono text-neutral-500 mt-2\">\n                  <span>0V</span>\n                  <span>Equivalente: {((selectedPin.value / 4095) * 3.3).toFixed(2)} Volts</span>\n                  <span>3.3V</span>\n                </div>\n              </div>\n\n              {/* Slider simulation */}\n              <div className=\"flex flex-col gap-1.5 bg-neutral-950/20 p-3 rounded-2xl border border-neutral-850/60\">\n                <div className=\"flex justify-between items-center text-[10px] font-mono\">\n                  <span className=\"text-neutral-400 uppercase tracking-widest font-bold\">Simular Sinal Anal\303\263gico</span>\n                  <button \n                    onClick={() => {\n                      setIsFluctuating(!isFluctuating);\n                      onAddLog(\'GPIO\', `${!isFluctuating ? \'Ativada\' : \'Pausada\'} flutua\303\247\303\243o rand\303\264mica do ADC ${selectedPin.gpio}`);\n                    }}\n                    className={`text-[9px] px-2 py-0.5 rounded-full font-bold border transition-all ${\n                      isFluctuating \n                        ? \'bg-purple-950/40 border-purple-800 text-purple-400\' \n                        : \'bg-neutral-950 border-neutral-800 text-neutral-500\'\n                    }`}\n                  >\n                    {isFluctuating ? \'Flutua\303\247\303\243o Ativa\' : \'Parado\'}\n                  </button>\n                </div>\n                <input \n                  type=\"range\"\n                  min=\"0\"\n                  max=\"4095\"\n                  value={selectedPin.value}\n                  onChange={handleAnalogChange}\n                  className=\"w-full accent-purple-500 cursor-pointer h-1.5 bg-neutral-800 rounded-lg appearance-none mt-1\"\n                />\n              </div>\n            </div>\n          )}\n\n          {selectedPin.mode === \'PWM_OUTPUT\' && (\n            <div className=\"flex flex-col gap-3.5\">\n              <div className=\"bg-neutral-950/30 p-3.5 rounded-2xl border border-neutral-850/85\">\n                <div className=\"flex justify-between items-center mb-1 font-mono text-[10px]\">\n                  <span className=\"text-neutral-400 uppercase tracking-widest font-bold flex items-center gap-1\">\n                    <Activity className=\"w-3.5 h-3.5 text-cyan-400\" /> Duty Cycle (8-bit)\n                  </span>\n                  <span className=\"text-cyan-400 font-bold\">{selectedPin.value} / 255</span>\n                </div>\n\n                <div className=\"w-full h-3 bg-neutral-950 rounded-full overflow-hidden border border-neutral-850/60 p-[1.5px] mt-2\">\n                  <div \n                    style={{ width: `${(selectedPin.value / 255) * 100}%` }}\n                    className=\"h-full bg-gradient-to-r from-cyan-500 to-blue-500 rounded-full transition-all duration-300\"\n                  />\n                </div>\n\n                <div className=\"flex justify-between items-center text-[9px] font-mono text-neutral-500 mt-2\">\n                  <span>0% (Off)</span>\n                  <span>Largura do Pulso: {Math.round((selectedPin.value / 255) * 100)}%</span>\n                  <span>100% (On)</span>\n                </div>\n              </div>\n\n              {/* PWM Adjust input */}\n              <div className=\"flex flex-col gap-1.5 bg-neutral-950/20 p-3 rounded-2xl border border-neutral-850/60\">\n                <span className=\"text-[10px] font-mono text-neutral-400 uppercase tracking-widest font-bold\">Ajustar Pot\303\252ncia</span>\n                <input \n                  type=\"range\"\n                  min=\"0\"\n                  max=\"255\"\n                  value={selectedPin.value}\n                  onChange={handlePwmChange}\n                  onMouseUp={handlePwmRelease}\n                  onTouchEnd={handlePwmRelease}\n                  className=\"w-full accent-cyan-500 cursor-pointer h-1.5 bg-neutral-800 rounded-lg appearance-none mt-1\"\n                />\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
