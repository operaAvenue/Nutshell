        }
        lines {
          text: "        // B. Simulate Analog ADC Fluctuation"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (pin.mode === \'ANALOG_INPUT\') {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          // slight fluctuation, standard ADC maximum range is 4095"
