          text: "    return () => clearInterval(simTimer);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  }, [pins]);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  // WiFi mode toggle with logging simulator"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const toggleWifiMode = () => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const nextMode = wifiSettings.mode === \'AP\' ? \'STA\' : \'AP\';"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    setWifiSettings(prev => ({ ...prev, mode: nextMode }));"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    addLog(\'WIFI\', `Modo de rede alternado para [${nextMode === \'AP\' ? \'PONTO DE ACESSO (AP)\' : \'ESTA\303\207\303\203O ROTEADOR (STA)\'}]`);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    if (nextMode === \'STA\') {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      addLog(\'WIFI\', `Requisitando endere\303\247o IP est\303\241tico ao Servidor DHCP...`);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      setTimeout(() => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        addLog(\'WIFI\', `Wi-Fi Conectado ao Gateway! IP atribu\303\255do: ${wifiSettings.staIp}`);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        addLog(\'HTTP\', `mDNS atualizado: Controle dispon\303\255vel em http://esp32-controller.local`);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      }, 1000);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    } else {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      addLog(\'WIFI\', `Rede P2P Wi-Fi configurada no IP Padr\303\243o: ${wifiSettings.apIp}`);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
