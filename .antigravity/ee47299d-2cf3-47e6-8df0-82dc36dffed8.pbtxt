        target_content: "  return (\n    <div id=\"main-panel\" className=\"min-h-screen bg-neutral-950 text-neutral-100 font-sans flex flex-col justify-between antialiased\">\n      \n      {/* BACKGROUND AMBIENT DETAILS */}\n      <div className=\"absolute top-0 left-0 right-0 h-[500px] bg-gradient-to-b from-blue-900/10 via-cyan-900/5 to-transparent pointer-events-none select-none\" />\n\n      {/* HEADER BAR */}\n      <header className=\"relative border-b border-neutral-900/80 bg-neutral-950/80 backdrop-blur-md px-6 py-4.5 flex justify-between items-center z-20\">\n        <div className=\"flex items-center gap-2.5\">\n          <div className=\"p-2 border border-cyan-500/20 bg-cyan-600/10 text-cyan-400 rounded-2xl\">\n            <Cpu className=\"w-5 h-5 animate-pulse\" />\n          </div>\n          <div>\n            <h1 className=\"text-sm font-bold tracking-tight text-white flex items-center gap-1.5\">\n              ESP32 IoT Dashboard\n              <span className=\"text-[9px] font-mono tracking-widest font-normal text-cyan-400/80 bg-cyan-950/40 border border-cyan-900/40 px-2 py-0.5 rounded-full select-none animate-pulse\">v2.5_STA</span>\n            </h1>\n            <p className=\"text-[10px] font-mono text-neutral-500 mt-0.5\">Controlador Wi-Fi nativo de alta efici\303\252ncia</p>\n          </div>\n        </div>\n\n        {/* Dynamic network indicators */}\n        <div className=\"flex items-center gap-3.5\">\n          <div className=\"hidden sm:flex items-center gap-2 bg-neutral-900/40 border border-neutral-850 py-1.5 px-3.5 rounded-2xl font-mono text-[9.5px] select-none text-neutral-400\">\n            <Radio className=\"w-3.5 h-3.5 text-neutral-500\" />\n            <span>Pino selecionado: </span>\n            <span className=\"font-bold text-cyan-400\">G{selectedPin.gpio}</span>\n          </div>\n\n          {/* Quick toggle between mobile viewer frame & responsive layout */}\n          <button \n            type=\"button\"\n            onClick={() => setIsFullscreen(!isFullscreen)}\n            className=\"flex items-center gap-1.5 px-3 py-2 bg-neutral-900 hover:bg-neutral-850 hover:text-white rounded-2xl text-[10.5px] font-bold border border-neutral-850 text-neutral-400 transition-all active:scale-95 cursor-pointer select-none\"\n            title=\"Alternar entre visualiza\303\247\303\243o de smartphone ou ocupar tela toda\"\n          >\n            <Tv className=\"w-3.5 h-3.5\" />\n            <span className=\"hidden sm:inline\">{isFullscreen ? \'Smartphone Frame\' : \'Full Screen\'}</span>\n          </button>\n        </div>\n      </header>\n\n      {/* CORE WORKSPACE container (Centering with device mockup if in Full Screen) */}\n      <main className=\"flex-1 relative z-10 px-4 sm:px-6 py-6 max-w-7xl mx-auto w-full flex flex-col justify-start\">\n        \n        {/* Device frame container IF isFullscreen is active */}\n        <div className={`transition-all duration-300 w-full ${isFullscreen ? \'\' : \'max-w-[480px] mx-auto bg-neutral-900/40 border border-neutral-850 p-5 rounded-[40px] shadow-2xl relative\'}`}>\n          \n          {/* Smart Phone details */}\n          {!isFullscreen && (\n            <div className=\"absolute top-2.5 left-1/2 -translate-x-1/2 w-32 h-4.5 bg-neutral-950 border border-neutral-850 rounded-full flex justify-center items-center select-none z-30 pointer-events-none\">\n              <span className=\"h-1.5 w-1.5 rounded-full bg-blue-600 mr-2\" />\n              <span className=\"h-1 w-12 rounded-full bg-neutral-800\" />\n            </div>\n          )}\n\n          <div className={`${isFullscreen ? \'\' : \'pt-7\'}`}>\n            \n            {/* NETWORK BANNER */}\n            <div className=\"bg-neutral-900/70 py-4 px-5 rounded-3xl border border-neutral-800/80 mb-5 flex items-center justify-between shadow-xl\">\n              <div className=\"flex items-center gap-3\">\n                <div onClick={toggleWifiMode} className={`p-2.5 rounded-2xl cursor-pointer border select-none transition-all ${\n                  wifiSettings.mode === \'AP\' \n                    ? \'bg-emerald-950/40 border-emerald-900/50 text-emerald-400 hover:bg-emerald-950\' \n                    : \'bg-blue-950/40 border-blue-900/50 text-blue-400 hover:bg-blue-950\'\n                }`}>\n                  <Wifi className=\"w-5 h-5 animate-pulse\" />\n                </div>\n                <div className=\"flex flex-col select-all\">\n                  <span className=\"text-xs font-bold text-neutral-200\">\n                    SSID: {wifiSettings.mode === \'AP\' ? wifiSettings.apSsid : wifiSettings.ssid}\n                  </span>\n                  <span className=\"text-[10px] font-mono text-neutral-500 mt-0.5\">\n                    Endere\303\247o IP: <strong className=\"text-cyan-400 font-bold\">{wifiSettings.mode === \'AP\' ? wifiSettings.apIp : wifiSettings.staIp}</strong>\n                  </span>\n                </div>\n              </div>\n\n              <div className=\"flex flex-col items-end\">\n                <button \n                  onClick={toggleWifiMode}\n                  className=\"text-[9.5px] font-bold text-neutral-400 hover:text-white uppercase tracking-wider font-mono cursor-pointer py-1 px-3 bg-neutral-950 border border-neutral-850 rounded-xl\"\n                >\n                  Reg: {wifiSettings.mode}\n                </button>\n              </div>\n            </div>\n\n            {/* TAB SELECTOR NAV */}\n            <nav className=\"grid grid-cols-4 gap-1 p-1 bg-neutral-950 rounded-2xl border border-neutral-900 mb-5 select-none\">\n              <button \n                onClick={() => setActiveTab(\'CONTROLS\')}\n                className={`py-2 px-1 rounded-xl flex flex-col items-center gap-1 transition-all cursor-pointer ${\n                  activeTab === \'CONTROLS\' \n                    ? \'bg-blue-600 text-white font-bold\' \n                    : \'text-neutral-555 hover:text-neutral-300\'\n                }`}\n              >\n                <Sliders className=\"w-4 h-4\" />\n                <span className=\"text-[8.5px] font-mono whitespace-nowrap\">Dashboard</span>\n              </button>\n              \n              <button \n                onClick={() => setActiveTab(\'MESH\')}\n                className={`py-2 px-1 rounded-xl flex flex-col items-center gap-1 transition-all cursor-pointer ${\n                  activeTab === \'MESH\' \n                    ? \'bg-blue-600 text-white font-bold\' \n                    : \'text-neutral-555 hover:text-neutral-300\'\n                }`}\n              >\n                <Layers className=\"w-4 h-4\" />\n                <span className=\"text-[8.5px] font-mono whitespace-nowrap\">Malha</span>\n              </button>\n              \n              <button \n                onClick={() => setActiveTab(\'FIRMWARE\')}\n                className={`py-2 px-1 rounded-xl flex flex-col items-center gap-1 transition-all cursor-pointer ${\n                  activeTab === \'FIRMWARE\' \n                    ? \'bg-blue-600 text-white font-bold\' \n                    : \'text-neutral-555 hover:text-neutral-300\'\n                }`}\n              >\n                <FileCode className=\"w-4 h-4\" />\n                <span className=\"text-[8.5px] font-mono whitespace-nowrap\">C++ Code</span>\n              </button>\n\n              <button \n                onClick={() => setActiveTab(\'AI_ASSIST\')}\n                className={`py-2 px-1 rounded-xl flex flex-col items-center gap-1 transition-all cursor-pointer ${\n                  activeTab === \'AI_ASSIST\' \n                    ? \'bg-blue-600 text-white font-bold\' \n                    : \'text-neutral-555 hover:text-neutral-300\'\n                }`}\n              >\n                <Sparkles className=\"w-4 h-4\" />\n                <span className=\"text-[8.5px] font-mono whitespace-nowrap\">Maker IA</span>\n              </button>\n            </nav>"
        replacement_content: "  return (\n    <div id=\"main-panel\" className=\"min-h-screen bg-[#090A0D] text-slate-200 font-sans flex flex-col justify-between antialiased\">\n      \n      {/* BACKGROUND AMBIENT DETAILS */}\n      <div className=\"absolute top-0 left-0 right-0 h-[500px] bg-gradient-to-b from-cyan-900/10 via-slate-900/5 to-transparent pointer-events-none select-none\" />\n\n      {/* HEADER BAR */}\n      <header className=\"relative border-b border-[#252833]/60 bg-[#12141C]/80 backdrop-blur-md px-6 py-4.5 flex justify-between items-center z-20\">\n        <div className=\"flex items-center gap-2.5\">\n          <div className=\"p-2 border border-cyan-500/20 bg-cyan-600/10 text-cyan-400 rounded-2xl\">\n            <Cpu className=\"w-5 h-5 animate-pulse\" />\n          </div>\n          <div>\n            <h1 className=\"text-sm font-bold tracking-tight text-white flex items-center gap-1.5 font-sans\">\n              ESP32 IoT Dashboard\n              <span className=\"text-[9px] font-mono tracking-widest font-bold text-cyan-500 bg-cyan-500/10 px-2 py-0.5 rounded uppercase select-none animate-pulse\">v2.5_STA</span>\n            </h1>\n            <p className=\"text-[10px] font-mono text-slate-500 mt-0.5\">Controlador Wi-Fi nativo de alta efici\303\252ncia</p>\n          </div>\n        </div>\n\n        {/* Dynamic network indicators */}\n        <div className=\"flex items-center gap-3.5\">\n          <div className=\"hidden sm:flex items-center gap-2 bg-[#1C1F2B] border border-white/5 py-1.5 px-3.5 rounded-2xl font-mono text-[9.5px] select-none text-slate-400\">\n            <Radio className=\"w-3.5 h-3.5 text-slate-500\" />\n            <span>Pino selecionado: </span>\n            <span className=\"font-bold text-cyan-400\">G{selectedPin.gpio}</span>\n          </div>\n\n          {/* Quick toggle between mobile viewer frame & responsive layout */}\n          <button \n            type=\"button\"\n            onClick={() => setIsFullscreen(!isFullscreen)}\n            className=\"flex items-center gap-1.5 px-3 py-2 bg-[#1C1F2B] hover:bg-[#252936] hover:text-white rounded-2xl text-[10.5px] font-bold border border-white/5 text-slate-400 transition-all active:scale-95 cursor-pointer select-none\"\n            title=\"Alternar entre visualiza\303\247\303\243o de smartphone ou ocupar tela toda\"\n          >\n            <Tv className=\"w-3.5 h-3.5 text-cyan-500\" />\n            <span className=\"hidden sm:inline\">{isFullscreen ? \'Smartphone Frame\' : \'Full Screen\'}</span>\n          </button>\n        </div>\n      </header>\n\n      {/* CORE WORKSPACE container (Centering with device mockup if in Full Screen) */}\n      <main className=\"flex-1 relative z-10 px-4 sm:px-6 py-6 max-w-7xl mx-auto w-full flex flex-col justify-start\">\n        \n        {/* Device frame container IF isFullscreen is active */}\n        <div className={`transition-all duration-300 w-full ${isFullscreen ? \'\' : \'max-w-[480px] mx-auto bg-[#12141C] border-[8px] border-[#252833] p-5 rounded-[48px] shadow-[0_0_80px_rgba(0,0,0,0.6)] relative overflow-hidden\'}`}>\n          \n          {/* Smart Phone details */}\n          {!isFullscreen && (\n            <div className=\"absolute top-2.5 left-1/2 -translate-x-1/2 w-32 h-4.5 bg-[#090A0D] border border-white/5 rounded-full flex justify-center items-center select-none z-30 pointer-events-none\">\n              <span className=\"h-1.5 w-1.5 rounded-full bg-cyan-600 mr-2 animate-pulse\" />\n              <span className=\"h-1 w-12 rounded-full bg-[#252833]\" />\n            </div>\n          )}\n\n          <div className={`${isFullscreen ? \'\' : \'pt-7\'}`}>\n            \n            {/* NETWORK BANNER */}\n            <div className=\"bg-[#1C1F2B] py-4 px-5 rounded-3xl border border-white/5 mb-5 flex items-center justify-between shadow-inner\">\n              <div className=\"flex items-center gap-3\">\n                <div onClick={toggleWifiMode} className={`p-2.5 rounded-2xl