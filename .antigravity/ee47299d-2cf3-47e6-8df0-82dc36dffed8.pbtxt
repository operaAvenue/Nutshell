    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "  return (\n    <div className=\"flex flex-col gap-5\">\n      {/* Introduction Card */}\n      <div className=\"bg-neutral-900/60 p-5 rounded-3xl border border-neutral-800 backdrop-blur-sm\">\n        <div className=\"flex items-center gap-2 mb-3\">\n          <BookOpen className=\"w-4 h-4 text-cyan-400\" />\n          <h4 className=\"text-xs font-bold uppercase tracking-wider text-neutral-300\">Como instalar no ESP32</h4>\n        </div>\n        <p className=\"text-neutral-400 text-xs leading-relaxed max-w-2xl\">\n          Como este app React \303\251 focado em <strong className=\"text-neutral-200\">baixo consumo de mem\303\263ria</strong>, ele pode ser gravado inteiramente no ESP32. Quando o seu ESP32 inicializa em modo Wi-Fi, ele cria a sua rede ou se conecta ao roteador, servindo esta mesma p\303\241gina aos celulares e computadores conectados na mesma rede local!\n        </p>\n\n        {/* Steps Guide */}\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3.5 mt-5\">\n          <div className=\"bg-neutral-950/40 p-3.5 rounded-2xl border border-neutral-850\">\n            <span className=\"text-[9px] font-mono font-bold px-2 py-0.5 bg-neutral-900 border border-neutral-800 rounded-lg text-cyan-400\">PASSO 1</span>\n            <h5 className=\"font-bold text-[11px] text-neutral-200 mt-2\">Compilar a Interface</h5>\n            <p className=\"text-[9.5px] text-neutral-500 mt-1 leading-normal\">\n              Execute <code className=\"bg-neutral-900 text-neutral-400 px-1 py-0.5 rounded\">npm run build</code> para gerar arquivos unificados de baixo footprint na pasta <code className=\"text-neutral-400\">dist/</code>.\n            </p>\n          </div>\n          <div className=\"bg-neutral-950/40 p-3.5 rounded-2xl border border-neutral-850\">\n            <span className=\"text-[9px] font-mono font-bold px-2 py-0.5 bg-neutral-900 border border-neutral-800 rounded-lg text-cyan-400\">PASSO 2</span>\n            <h5 className=\"font-bold text-[11px] text-neutral-200 mt-2\">Gzip & Prepara\303\247\303\243o</h5>\n            <p className=\"text-[9.5px] text-neutral-500 mt-1 leading-normal\">\n              Comprima o HTML buildado para <code className=\"text-neutral-400 font-mono\">.gz</code>. Isso reduz seu peso para cerca de <strong className=\"text-neutral-300\">22KB</strong>, ocupando pouqu\303\255ssimo espa\303\247o!\n            </p>\n          </div>\n          <div className=\"bg-neutral-950/40 p-3.5 rounded-2xl border border-neutral-850\">\n            <span className=\"text-[9px] font-mono font-bold px-2 py-0.5 bg-neutral-900 border border-neutral-850 rounded-lg text-cyan-400\">PASSO 3</span>\n            <h5 className=\"font-bold text-[11px] text-neutral-200 mt-2\">Grava\303\247\303\243o Arduino</h5>\n            <p className=\"text-[9.5px] text-neutral-500 mt-1 leading-normal\">\n              Copie o c\303\263digo C++ abaixo e fa\303\247a o upload no seu ESP32 usando a IDE cl\303\241ssica ou VSCode PlatformIO.\n            </p>\n          </div>\n        </div>\n      </div>\n\n      {/* Code exporter container */}\n      <div className=\"bg-neutral-900/60 p-5 rounded-3xl border border-neutral-800 backdrop-blur-sm flex flex-col\">\n        <div className=\"flex justify-between items-center pb-3 border-b border-neutral-850 mb-4 flex-wrap gap-2\">\n          {/* Tabs for select flashing architecture */}\n          <div className=\"flex items-center gap-3\">\n            <FileCode className=\"w-4 h-4 text-blue-400\" />\n            <h4 className=\"text-xs font-bold uppercase tracking-wider text-neutral-300 mr-2\">C\303\263digo Firmware Arduino</h4>\n            \n            <div className=\"flex bg-neutral-950 p-1 rounded-xl border border-neutral-850\">\n              <button \n                onClick={() => setExportMethod(\'PROGMEM\')}\n                className={`text-[9.5px] font-bold px-3 py-1 rounded-lg transition-all ${exportMethod === \'PROGMEM\' ? \'bg-blue-600 text-white font-mono\' : \'text-neutral-500 hover:text-neutral-300\'}`}\n              >\n                PROGMEM (Inline Flash)\n              </button>\n              <button \n                onClick={() => setExportMethod(\'LITTLEFS\')}\n                className={`text-[9.5px] font-bold px-3 py-1 rounded-lg transition-all ${exportMethod === \'LITTLEFS\' ? \'bg-blue-600 text-white font-mono\' : \'text-neutral-500 hover:text-neutral-300\'}`}\n              >\n                LittleFS Partition\n              </button>\n            </div>\n          </div>\n\n          <button \n            onClick={() => copyCodeToClipboard(generateArduinoCode())}\n            className=\"flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[10.5px] font-bold bg-neutral-950 hover:bg-neutral-900 border border-neutral-850 hover:border-neutral-700 text-neutral-300 transition-all active:scale-95\"\n          >\n            {copied ? <Check className=\"w-3.5 h-3.5 text-emerald-400\" /> : <Clipboard className=\"w-3.5 h-3.5\" />}\n            {copied ? \'Copiado!\' : \'Copiar C++\'}\n          </button>\n        </div>\n\n        {/* Warning panel about mDNS and CORS */}\n        <div className=\"mb-4 flex items-start gap-2.5 bg-yellow-950/15 border border-yellow-900/35 p-3 rounded-2xl\">\n          <AlertTriangle className=\"w-4 h-4 text-yellow-500 flex-shrink-0 mt-0.5\" />\n          <div className=\"flex flex-col gap-0.5\">\n            <span className=\"text-[10px] font-bold text-yellow-400 font-mono\">DICA DE ARQUITETURA MULTI-N\303\223 (P2P Wi-Fi)</span>\n            <p className=\"text-[9px] text-neutral-450 leading-relaxed font-mono\">\n              O firmware gerado habilita automaticamente os cabe\303\247alhos de <strong className=\"text-neutral-300\">CORS (*)</strong> para o ESPAsyncWebServer. Isso possibilita que os n\303\263s troquem dados diretamente em chamadas AJAX transparentes no navegador dos usu\303\241rios, descobrindo uns aos outros nativamente no Wi-Fi sem a necessidade de um servidor de nuvem externo!\n            </p>\n          </div>\n        </div>\n\n        {/* Code display window */}\n        <div className=\"relative bg-neutral-950 rounded-2xl border border-neutral-850 max-h-[380px] overflow-auto\">\n          <pre className=\"p-4 text-[10px] font-mono text-neutral-400 leading-normal whitespace-pre\">\n            {generateArduinoCode()}\n          </pre>\n        </div>\n\n        <div className=\"flex justify-between items-center text-[9px] font-mono text-neutral-500 mt-3\">\n          <span className=\"flex items-center gap-1\">\n            <Cpu className=\"w-3 h-3 text-cyan-600\" />\n            Configura\303\247\303\243o Din\303\242mica baseada nos pinos em uso\n          </span>\n          <span>BaudRate sugerido: 115200 bps</span>\n        </div>\n      </div>\n    </div>"
      replacement_content: "  return (\n    <div className=\"flex flex-col gap-5\">\n      {/* Introduction Card */}\n      <div className=\"bg-[#1C1F2B] p-5 rounded-3xl border border-white/5 shadow-inner backdrop-blur-sm\">\n        <div className=\"flex items-center gap-2 mb-3\">\n          <BookOpen className=\"w-4 h-4 text-cyan-400\" />\n          <h4 className=\"text-xs font-bold uppercase tracking-wider text-slate-300\">Como instalar no ESP32</h4>\n        </div>\n        <p className=\"text-slate-400 text-xs leading-relaxed max-w-2xl\">\n          Como este app React \303\251 focado em <strong className=\"text-slate-200\">baixo consumo de mem\303\263ria</strong>, ele pode ser gravado inteiramente no ESP32. Quando o seu ESP32 inicializa em modo Wi-Fi, ele cria a sua rede ou se conecta ao roteador, servindo esta mesma p\303\241gina aos celulares e computadores conectados na mesma rede local!\n        </p>\n\n        {/* Steps Guide */}\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3.5 mt-5\">\n          <div className=\"bg-[#12141C] p-3.5 rounded-2xl border border-white/5\">\n            <span className=\"text-[9px] font-mono font-bold px-2 py-0.5 bg-[#252936] border border-white/5 rounded-lg text-cyan-400\">PASSO 1</span>\n            <h5 className=\"font-bold text-[11px] text-slate-200 mt-2\">Compilar a Interface</h5>\n            <p className=\"text-[9.5px] text-slate-500 mt-1 leading-normal\">\n              Execute <code className=\"bg-[#1C1F2B] text-slate-400 px-1 py-0.5 rounded\">npm run build</code> para gerar arquivos unificados de baixo footprint na pasta <code className=\"text-slate-400 font-mono\">dist/</code>.\n            </p>\n          </div>\n          <div className=\"bg-[#12141C] p-3.5 rounded-2xl border border-white/5\">\n            <span className=\"text-[9px] font-mono font-bold px-2 py-0.5 bg-[#252936] border border-white/5 rounded-lg text-cyan-400\">PASSO 2</span>\n            <h5 className=\"font-bold text-[11px] text-slate-200 mt-2\">Gzip & Prepara\303\247\303\243o</h5>\n            <p className=\"text-[9.5px] text-slate-500 mt-1 leading-normal\">\n              Comprima o HTML buildado para <code className=\"text-slate-400 font-mono\">.gz</code>. Isso reduz seu peso para cerca de <strong className=\"text-slate-300\">22KB</strong>, ocupando pouqu\303\255ssimo espa\303\247o!\n            </p>\n          </div>\n          <div className=\"bg-[#12141C] p-3.5 rounded-2xl border border-white/5\">\n            <span className=\"text-[9px] font-mono font-bold px-2 py-0.5 bg-[#252936] border border-white/5 rounded-lg text-cyan-400\">PASSO 3</span>\n            <h5 className=\"font-bold text-[11px] text-slate-200 mt-2\">Grava\303\247\303\243o Arduino</h5>\n            <p className=\"text-[9.5px] text-slate-500 mt-1 leading-normal\">\n              Copie o c\303\263digo C++ abaixo e fa\303\247a o upload no seu ESP32 usando a IDE cl\303\241ssica ou VSCode PlatformIO.\n            </p>\n          </div>\n        </div>\n      </div>\n\n      {/* Code exporter container */}\n      <div className=\"bg-[#1C1F2B] p-5 rounded-3xl border border-white/5 backdrop-blur-sm flex flex-col shadow-inner\">\n        <div className=\"flex justify-between items-center pb-3 border-b border-[#252833]/60 mb-4 flex-wrap gap-2\">\n          {/* Tabs for select flashing architecture */}\n          <div className=\"flex items-center gap-3\">\n            <FileCode className=\"w-4 h-4 text-cyan-455\" />\n            <h4 className=\"text-xs font-bold uppercase tracking-wider text-slate-300 mr-2\">C\303\263digo Firmware Arduino</h4>\n            \n            <div className=\"flex bg-[#12141C] p-1 rounded-xl border border-white/5\">\n              <button \n                onClick={() => setExportMethod(\'PROGMEM\')}\n                className={`text-[9.5px] font-bold px-3 py-1 rounded-lg transition-all cursor-pointer ${exportMethod === \'PROGMEM\' ? \'bg-cyan-500 text-slate-950 font-mono shadow-sm\' : \'text-slate-500 hover:text-slate-300\'}`}\n              >\n                PROGMEM (Inline Flash)\n              </button>\n              <button \n                onClick={() => setExportMethod(\'LITTLEFS\')}\n                className={`text-[9.5px] font-bold px-3 py-1 rounded-lg transition-all cursor-pointer ${exportMethod === \'LITTLEFS\' ? \'bg-cyan-500 text-slate-950 font-mono shadow-sm\' : \'text-slate-500 hover:text-slate-300\'}`}\n              >\n                LittleFS Partition\n              </button>\n            </div>\n          </div>\n\n          <button \n            onClick={() => copyCodeToClipboard(generateArduinoCode())}\n            className=\"flex items-center gap-1.5 px-3.5 py-1.5 rounded-xl text-[10.5px] font-bold bg-[#12141C] hover:bg-[#252936] border border-white/5 hover:border-slate-700 text-slate-300 transition-all active:scale-95 cursor-pointer\"\n          >\n            {copied ? <Check className=\"w-3.5 h-3.5 text-emerald-400\" /> : <Clipboard className=\"w-3.5 h-3.5 text-cyan-400\" />}\n            {copied ? \'Copiado!\' : \'Copiar C++\'}\n          </button>\n        </div>\n\n        {/* Warning panel about mDNS and CORS */}\n        <div className=\"mb-4 flex items-start gap-2.5 bg-yellow-950/10 border border-yellow-905/30 p-3 rounded-2xl\">\n          <AlertTriangle className=\"w-4 h-4 text-yellow-500 flex-shrink-0 mt-0.5\" />\n          <div className=\"flex flex-col gap-0.5\">\n            <span className=\"text-[10px] font-bold text-yellow-505 font-mono\">DICA DE ARQUITETURA MULTI-N\303\223 (P2P Wi-Fi)</span>\n            <p className=\"text-[9px] text-slate-400 leading-relaxed font-mono\">\n              O firmware gerado habilita automaticamente os cabe\303\247alhos de <strong className=\"text-slate-300\">CORS (*)</strong> para o ESPAsyncWebServer. Isso possibilita que os n\303\263s troquem dados diretamente em chamadas AJAX transparentes no navegador dos usu\303\241rios, descobrindo uns aos outros nativamente no Wi-Fi sem a necessidade de um servidor de nuvem externo!\n            </p>\n          </div>\n        </div>\n\n        {/* Code display window */}\n        <div className=\"relative bg-[#12141C] rounded-2xl border border-white/5 max-h-[380px] overflow-auto shadow-inner\">\n          <pre className=\"p-4 text-[10px] font-mono text-slate-400 leading-normal whitespace-pre\">\n            {generateArduinoCode()}\n          </pre>\n        </div>\n\n        <div className=\"flex justify-between items-center text-[9px] font-mono text-slate-500 mt-3\">\n          <span className=\"flex items-center gap-1\">\n            <Cpu className=\"w-3 h-3 text-cyan-600 animate-pulse\" />\n            Configura\303\247\303\243o Din\303\242mica baseada nos pinos em uso\n          </span>\n          <span>BaudRate sugerido: 115200 bps</span>\n        </div>\n      </div>\n    </div>"
    }
    instruction: "Update FirmwareExporter.tsx panels, inputs, warnings, and code block components to Sleek styles and glowing cyans"
  }
}
