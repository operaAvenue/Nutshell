    replacement_chunks {
      replacement_content: "import express from \'express\';\nimport path from \'path\';\nimport { createServer as createViteServer } from \'vite\';\nimport { GoogleGenAI } from \'@google/genai\';\nimport dotenv from \'dotenv\';\n\ndotenv.config();\n\n// Transient in-memory ESP32 simulation pin state\nconst simPins = [\n  { gpio: 2, name: \'GPIO 2\', mode: \'DIGITAL_OUTPUT\', customLabel: \'Onboard LED (Azul)\', value: 0 },\n  { gpio: 4, name: \'GPIO 4\', mode: \'DIGITAL_OUTPUT\', customLabel: \'Rel\303\251 L\303\242mpada\', value: 0 },\n  { gpio: 14, name: \'GPIO 14\', mode: \'PWM_OUTPUT\', customLabel: \'Brilho Fita LED\', value: 128 },\n  { gpio: 32, name: \'GPIO 32\', mode: \'ANALOG_INPUT\', customLabel: \'Sensor de Umidade\', value: 1820 },\n  { gpio: 33, name: \'GPIO 33\', mode: \'ANALOG_INPUT\', customLabel: \'Sensor de Luz (LDR)\', value: 2450 }\n];\n\nasync function startServer() {\n  const app = express();\n  const PORT = 3000;\n\n  app.use(express.json());\n\n  // API ROUTE: Get Simulated ESP32 Pin status (Mirroring physical board endpoints)\n  app.get(\'/api/status\', (req, res) => {\n    res.json({\n      hostname: \'esp32-master-sim\',\n      ip: \'192.168.4.1\',\n      heap: 284,\n      wifi_rssi: -35,\n      wifiMode: \'AP\',\n      pins: simPins\n    });\n  });\n\n  // API ROUTE: Toggle Pin (Mirroring physical board controls)\n  app.get(\'/api/toggle\', (req, res) => {\n    const pinGpio = parseInt(req.query.pin as string, 10);\n    const valueNum = parseInt(req.query.val as string, 10);\n\n    const pin = simPins.find(p => p.gpio === pinGpio);\n    if (pin) {\n      pin.value = valueNum;\n      console.log(`[Sim Server] GPIO ${pinGpio} alternado localmente para ${valueNum}`);\n      return res.json({ status: \'success\', pin: pinGpio, val: valueNum });\n    }\n    return res.status(404).json({ error: \'Pin not configured\' });\n  });\n\n  // API ROUTE: Gemini AI assist for customized C++ / ESP32 guidance\n  app.post(\'/api/gemini/assist\', async (req, res) => {\n    const { prompt } = req.body;\n    if (!prompt) {\n      return res.status(400).json({ error: \'O prompt de comando \303\251 obrigat\303\263rio.\' });\n    }\n\n    try {\n      const gKey = process.env.GEMINI_API_KEY;\n      if (!gKey || gKey === \'MY_GEMINI_API_KEY\') {\n        // Return a mock fallback if key is not configured, to improve user experience gracefully\n        return res.json({\n          text: `## Ol\303\241! (Modo Simulado sem Chave de API)\n\nParece que a chave **GEMINI_API_KEY** n\303\243o foi configurada nos segredos ou no arquivo .env. \n\nContudo, aqui est\303\241 um exemplo de automa\303\247\303\243o cl\303\241ssica para o ESP32 que voc\303\252 pode implementar:\n\n\\`\\`\\`cpp\n// Exemplo de L\303\263gica de Automa\303\247\303\243o por Sensor (LDR na GPIO 33 acionando Rel\303\251 na GPIO 4)\nvoid loop() {\n  int ldrValue = analogRead(33); // L\303\252 o sensor de luz\n  Serial.print(\"Luminosidade: \");\n  Serial.println(ldrValue);\n\n  if (ldrValue > 3000) { // Ambiente escuro\n    digitalWrite(4, HIGH); // Liga o rel\303\251 da l\303\242mpada\n  } else {\n    digitalWrite(4, LOW);  // Desliga o rel\303\251 da l\303\242mpada\n  }\n  delay(1000); // Aguarda 1 segundo\n}\n\\`\\`\\`\n\nAdicione sua chave **GEMINI_API_KEY** no painel de Configura\303\247\303\265es > Secrets para habilitar consultas customizadas de IA em tempo real!`\n        });\n      }\n\n      // Initialize GoogleGenAI SDK with appropriate system rules and user agent telemetry\n      const ai = new GoogleGenAI({\n        apiKey: gKey,\n        httpOptions: {\n          headers: {\n            \'User-Agent\': \'aistudio-build\'\n          }\n        }\n      });\n\n      const response = await ai.models.generateContent({\n        model: \'gemini-3.5-flash\',\n        contents: prompt,\n        config: {\n          systemInstruction: `Voc\303\252 \303\251 o \"ESP32 Maker Genius\", um engenheiro eletrot\303\251cnico veterano especialista em hardware ESP32, Internet das Coisas (IoT), interfaceamento com sensores (DHT22, LDR, Ultrass\303\264nico, RTC, RFID, etc.) e barramentos (I2C, SPI, UART).\nVoc\303\252 deve fornecer respostas focadas, limpas, motivadoras e extremamente precisas em FORMATO MARKDOWN.\nSe o usu\303\241rio lhe perguntar sobre circuitos, explique de forma simples (\"VCC no ESP32 3V3, GND no GND, OUT na GPIO 15\").\nSe fornecer c\303\263digo em C++/Arduino, sempre adicione coment\303\241rios descritivos e use pr\303\241ticas eficientes para economizar mem\303\263ria RAM (como uso de F() macro e PROGMEM se aplic\303\241vel). Responda sempre em portugu\303\252s brasileiro.`\n        }\n      });\n\n      res.json({ text: response.text });\n    } catch (err: any) {\n      console.error(\'Error contacting Gemini service:\', err);\n      res.status(500).json({ error: \'Erro inesperado ao consultar a API Gemini: \' + err.message });\n    }\n  });\n\n  // Serve static UI / Webpack compilation\n  if (process.env.NODE_ENV !== \'production\') {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \'spa\'\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \'dist\');\n    app.use(express.static(distPath));\n    app.get(\'*\', (req, res) => {\n      res.sendFile(path.join(distPath, \'index.html\'));\n    });\n  }\n\n  app.listen(PORT, \'0.0.0.0\', () => {\n    console.log(`[ESP32 Sim Server] Running on http://localhost:${PORT}`);\n    console.log(`[ESP32 Sim Server] Dev mode: ${process.env.NODE_ENV !== \'production\'}`);\n  });\n}\n\nstartServer();\n"
    }
