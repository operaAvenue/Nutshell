rounded-2xl\\\">\\n            <p class=\\\"text-[10px] text-slate-500 uppercase mb-1 tracking-widest\\\">Brightness</p>\\n            <p class=\\\"text-xl font-light text-white\\\">84<span class=\\\"text-xs text-slate-500 ml-0.5\\\">%</span></p>\\n          </div>\\n          <div class=\\\"bg-[#252936] p-4 rounded-2xl\\\">\\n            <p class=\\\"text-[10px] text-slate-500 uppercase mb-1 tracking-widest\\\">Temp</p>\\n            <p class=\\\"text-xl font-light text-white\\\">24.5<span class=\\\"text-xs text-slate-500 ml-0.5\\\">\302\260C</span></p>\\n          </div>\\n        </div>\\n      </div>\\n\\n      <!-- Mesh Nodes -->\\n      <div>\\n        <div class=\\\"flex justify-between items-center mb-4\\\">\\n          <h2 class=\\\"text-sm font-semibold text-slate-300 uppercase tracking-widest\\\">Mesh Network (3)</h2>\\n          <div class=\\\"w-4 h-4 rounded-full border-2 border-slate-700 border-t-cyan-500\\\"></div>\\n        </div>\\n\\n        <div class=\\\"space-y-3\\\">\\n          <!-- Peer Node 1 -->\\n          <div class=\\\"flex items-center justify-between bg-[#171A24] p-4 rounded-2xl border border-white/5\\\">\\n            <div class=\\\"flex items-center gap-3\\\">\\n              <div class=\\\"w-10 h-10 bg-[#252936] rounded-xl flex items-center justify-center text-cyan-400 font-mono text-sm\\\">02</div>\\n              <div>\\n                <p class=\\\"text-sm font-medium text-white\\\">Kitchen ESP</p>\\n                <p class=\\\"text-[10px] text-slate-500\\\">Signal: -64dBm</p>\\n              </div>\\n            </div>\\n            <div class=\\\"w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_#10b981]\\\"></div>\\n          </div>\\n          <!-- Peer Node 2 -->\\n          <div class=\\\"flex items-center justify-between bg-[#171A24] p-4 rounded-2xl border border-white/5 opacity-80\\\">\\n            <div class=\\\"flex items-center gap-3\\\">\\n              <div class=\\\"w-10 h-10 bg-[#252936] rounded-xl flex items-c