          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const safeLabel = p.customLabel.toUpperCase().replace(/\\s+/g, \'_\').replace(/[^a-zA-Z0-9_]/g, \'\');"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      let valGetter = `0`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      if (isOutput) valGetter = `digitalRead(PIN_${safeLabel})`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      if (isInput) valGetter = `digitalRead(PIN_${safeLabel})`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      if (isAnalog) valGetter = `analogRead(PIN_${safeLabel})`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      if (isPwm) valGetter = `ledcRead(PWM_CHAN_${safeLabel})`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      return `"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
