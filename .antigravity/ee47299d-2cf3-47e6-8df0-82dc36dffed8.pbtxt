        }
        lines {
          text: "      p[\"gpio\"] = ${p.gpio};"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      p[\"mode\"] = \"${p.mode}\";"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
