        }
        lines {
          text: "  ${outputPins.map(p => `pinMode(PIN_${p.customLabel.toUpperCase().replace(/\\s+/g, \'_\').replace(/[^a-zA-Z0-9_]/g, \'\')}, OUTPUT);\\n  digitalWrite(PIN_${p.customLabel.toUpperCase().replace(/\\s+/g, \'_\').replace(/[^a-zA-Z0-9_]/g, \'\')}, LOW);`).join(\'\\n  \')}"
